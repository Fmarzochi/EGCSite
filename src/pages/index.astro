---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const b = import.meta.env.BASE_URL;
const base = b.endsWith('/') ? b : b + '/';
---

<Base title="EGC - Extended Global Context" description="Your AI remembers your project across sessions and tools. Persistent memory and shared context for every AI coding tool.">
  <Navbar />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-b from-gray-50 via-white to-white dark:from-gray-900 dark:via-gray-950 dark:to-gray-950 pt-16 pb-20 sm:pt-24 sm:pb-28">
      <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
        <div class="absolute left-1/2 top-0 -translate-x-1/2 w-[900px] h-[500px] rounded-full bg-egc-500/5 blur-3xl dark:bg-egc-500/10"></div>
      </div>
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-egc-50 dark:bg-egc-950/50 border border-egc-200 dark:border-egc-900 text-egc-700 dark:text-egc-300 text-xs font-medium mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-egc-500 animate-pulse"></span>
          v1.0.0 now available
          <a href="https://github.com/Fmarzochi/EGC/releases" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2">See release</a>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-6 leading-tight">
          Your AI remembers your<br class="hidden sm:block" />
          <span class="text-egc-600 dark:text-egc-400">project across sessions</span><br class="hidden sm:block" />
          and tools.
        </h1>

        <p class="mx-auto max-w-2xl text-lg text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
          EGC is an open-source runtime that gives every AI coding tool a shared, persistent memory of your project. Install once, works everywhere.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-10">
          <a href={`${base}get-started`} class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-egc-600 text-white font-semibold hover:bg-egc-700 transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-egc-500 focus:ring-offset-2">
            Get Started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a href="https://github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-700 dark:text-gray-300 font-semibold hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors duration-150">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            GitHub
          </a>
        </div>

        <div class="max-w-xl mx-auto rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 shadow-xl">
          <div class="flex items-center gap-1.5 px-4 py-3 bg-gray-900 border-b border-gray-700">
            <span class="w-3 h-3 rounded-full bg-red-500"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
            <span class="w-3 h-3 rounded-full bg-green-500"></span>
            <span class="ml-2 text-xs text-gray-400 font-mono">bash</span>
          </div>
          <div class="bg-gray-900 p-5 text-left font-mono text-sm text-gray-100 leading-relaxed overflow-x-auto">
            <div class="text-gray-400"># Clone and install</div>
            <div><span class="text-egc-400">$</span> git clone https://github.com/Fmarzochi/EGC.git</div>
            <div><span class="text-egc-400">$</span> cd EGC && sh install.sh</div>
            <div class="mt-3 text-gray-400"># Verify</div>
            <div><span class="text-egc-400">$</span> egc doctor</div>
            <div class="mt-2 text-egc-400">egc-guardian <span class="text-green-400">running</span></div>
            <div class="text-egc-400">egc-memory <span class="text-green-400">running</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hero image -->
    <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 -mt-4 mb-16">
      <div class="rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 shadow-2xl">
        <img src={`${base}hero.png`} alt="EGC - Extended Global Context dashboard showing persistent memory across AI tools" class="w-full" loading="lazy" />
      </div>
    </section>

    <!-- Stats -->
    <section class="border-y border-gray-100 dark:border-gray-800/50 bg-gray-50/50 dark:bg-gray-900/30 py-10 mb-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {[
            { value: '9', label: 'Supported Tools' },
            { value: '228+', label: 'Skills' },
            { value: '74', label: 'Commands' },
            { value: '100%', label: 'Open Source' },
          ].map(stat => (
            <div>
              <div class="text-3xl font-extrabold text-egc-600 dark:text-egc-400 mb-1">{stat.value}</div>
              <div class="text-sm text-gray-500 dark:text-gray-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- The Problem -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-20">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-3">The Problem</p>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4 leading-tight">Every AI session starts from zero.</h2>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-4">Close the window and the context is gone. Your stack preferences, the architectural decisions you made last week, the approach that failed after three attempts. Next session you spend the first ten minutes re-explaining ground you already covered.</p>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">It gets worse when you switch tools. Move from Cursor to Claude Code and you start over again. The AI doesn't know you. It never did.</p>
        </div>
        <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 font-mono text-sm">
          <div class="text-gray-400 mb-3 text-xs">Without EGC</div>
          <div class="space-y-2 text-gray-500 dark:text-gray-500">
            <div class="line-through">You: We're using PostgreSQL with row-level security...</div>
            <div class="line-through">You: I prefer functional components, no classes...</div>
            <div class="line-through">You: We tried Prisma but moved to Drizzle because...</div>
            <div class="line-through">You: The auth flow uses sessions, not JWT...</div>
          </div>
          <div class="mt-4 text-gray-400 text-xs">Every. Single. Session.</div>
        </div>
      </div>
    </section>

    <!-- How EGC fixes it -->
    <section class="bg-gray-50 dark:bg-gray-900/50 py-20 mb-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-3">The Solution</p>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">One install. Every tool. Permanent memory.</h2>
          <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">sh install.sh detects which AI tools you have and registers the MCP servers in all of them. The AI reads your project state at the start of every session and saves decisions at the end.</p>
        </div>

        <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden mb-8">
          <div class="flex items-center gap-1.5 px-4 py-3 bg-gray-900 border-b border-gray-700">
            <span class="w-3 h-3 rounded-full bg-red-500"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
            <span class="w-3 h-3 rounded-full bg-green-500"></span>
            <span class="ml-2 text-xs text-gray-400 font-mono">With EGC</span>
          </div>
          <div class="bg-gray-900 p-5 font-mono text-sm text-gray-100 overflow-x-auto">
            <div class="text-gray-400"># You open Claude Code on a project you haven't touched in 2 weeks.</div>
            <div class="text-gray-400"># Without typing anything:</div>
            <div class="mt-3 text-egc-400">State loaded from egc-memory</div>
            <div class="text-green-400 mt-1">Context and preferences acknowledged (terse responses).</div>
            <div class="text-green-400">Ready to pick up:</div>
            <div class="text-gray-300 ml-2">• Test full install on a clean machine</div>
            <div class="text-gray-300 ml-2">• Add GEMINI.md with session memory protocol</div>
            <div class="text-gray-300 ml-2">• Tag v1.0.0 after clean install test passes</div>
          </div>
        </div>

        <div class="grid sm:grid-cols-3 gap-6">
          {[
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>',
              title: 'Open any session',
              description: 'AI reads your project state and picks up where you left off.',
            },
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/>',
              title: 'Close any session',
              description: 'AI saves decisions, preferences, and next steps automatically.',
            },
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>',
              title: 'Switch any tool',
              description: 'Same state file, same context. No re-explaining.',
            },
          ].map(card => (
            <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
              <div class="w-10 h-10 rounded-xl bg-egc-50 dark:bg-egc-900/30 flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-egc-600 dark:text-egc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={card.icon}></svg>
              </div>
              <h3 class="font-semibold text-gray-900 dark:text-white mb-2">{card.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Supported Tools -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-3">Ecosystem</p>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Works with every AI coding tool</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        {[
          { name: 'Claude Code', badge: 'MCP + Bootstrap' },
          { name: 'Cursor', badge: 'MCP + Bootstrap' },
          { name: 'Codex CLI', badge: 'MCP + Bootstrap' },
          { name: 'Gemini CLI', badge: 'MCP + Bootstrap' },
          { name: 'OpenCode', badge: 'MCP + Bootstrap' },
          { name: 'Kiro', badge: 'MCP + Bootstrap' },
          { name: 'Trae', badge: 'Context + Bootstrap' },
          { name: 'CodeBuddy', badge: 'Context + Bootstrap' },
          { name: 'Antigravity', badge: 'MCP + Bootstrap' },
        ].map(tool => (
          <div class="flex flex-col items-center gap-2 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4 text-center hover:border-egc-300 dark:hover:border-egc-800 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
              <span class="text-lg font-bold text-gray-400 dark:text-gray-600">{tool.name[0]}</span>
            </div>
            <div class="text-xs font-semibold text-gray-900 dark:text-gray-100">{tool.name}</div>
            <div class="text-xs text-egc-600 dark:text-egc-400">{tool.badge}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- MCP Servers -->
    <section class="bg-gray-50 dark:bg-gray-900/50 py-20 mb-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-3">MCP Servers</p>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Two local servers, zero cloud</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="rounded-2xl border border-egc-200 dark:border-egc-900 bg-white dark:bg-gray-900 p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-egc-50 dark:bg-egc-900/50 flex items-center justify-center">
                <svg class="w-5 h-5 text-egc-600 dark:text-egc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white font-mono">egc-memory</h3>
                <p class="text-xs text-gray-500 dark:text-gray-400">The one you'll use every session</p>
              </div>
            </div>
            <div class="space-y-2">
              {[
                { tool: 'get_state', desc: 'Reads project memory at session start' },
                { tool: 'update_state', desc: 'Saves this session\'s decisions and next steps' },
                { tool: 'store_decision', desc: 'Persists a decision to SQLite' },
                { tool: 'query_history', desc: 'Returns past decisions by timestamp' },
              ].map(row => (
                <div class="flex items-start gap-3">
                  <code class="text-xs px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200 font-mono shrink-0">{row.tool}</code>
                  <span class="text-xs text-gray-600 dark:text-gray-400">{row.desc}</span>
                </div>
              ))}
            </div>
            <a href={`${base}docs/memory`} class="mt-5 inline-flex items-center gap-1 text-xs font-semibold text-egc-600 dark:text-egc-400 hover:underline">
              Read docs
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          </div>

          <div class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                <svg class="w-5 h-5 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white font-mono">egc-guardian</h3>
                <p class="text-xs text-gray-500 dark:text-gray-400">Runs in the background</p>
              </div>
            </div>
            <div class="space-y-2">
              {[
                { tool: 'validate_command', desc: 'Blocks shell injection and unsafe binaries' },
                { tool: 'validate_write', desc: 'Blocks writes to sensitive paths (~/.ssh, /etc)' },
                { tool: 'reduce_context', desc: 'Deduplicates and trims Markdown payloads' },
                { tool: 'orchestrate_task', desc: 'Routes prompts to relevant agents and skills' },
              ].map(row => (
                <div class="flex items-start gap-3">
                  <code class="text-xs px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200 font-mono shrink-0">{row.tool}</code>
                  <span class="text-xs text-gray-600 dark:text-gray-400">{row.desc}</span>
                </div>
              ))}
            </div>
            <a href={`${base}docs/guardian`} class="mt-5 inline-flex items-center gap-1 text-xs font-semibold text-egc-600 dark:text-egc-400 hover:underline">
              Read docs
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Token savings -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-20">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-3">Efficiency</p>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white">87% fewer tokens to rebuild context</h2>
      </div>
      <div class="rounded-2xl border border-gray-200 dark:border-gray-800 overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
              <th class="px-6 py-4 text-left font-semibold text-gray-900 dark:text-white"></th>
              <th class="px-6 py-4 text-center font-semibold text-gray-900 dark:text-white">Without EGC</th>
              <th class="px-6 py-4 text-center font-semibold text-egc-600 dark:text-egc-400">With EGC</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <tr class="bg-white dark:bg-gray-950">
              <td class="px-6 py-4 text-gray-700 dark:text-gray-300">Context overhead per session</td>
              <td class="px-6 py-4 text-center text-gray-500 dark:text-gray-400">~1,500 tokens</td>
              <td class="px-6 py-4 text-center text-egc-600 dark:text-egc-400 font-semibold">~200 tokens</td>
            </tr>
            <tr class="bg-gray-50/50 dark:bg-gray-900/30">
              <td class="px-6 py-4 text-gray-700 dark:text-gray-300">Cost for 20 sessions/month</td>
              <td class="px-6 py-4 text-center text-gray-500 dark:text-gray-400">~$0.08-0.09</td>
              <td class="px-6 py-4 text-center text-egc-600 dark:text-egc-400 font-semibold">~$0.011-0.012</td>
            </tr>
            <tr class="bg-white dark:bg-gray-950">
              <td class="px-6 py-4 text-gray-700 dark:text-gray-300">Time re-explaining context</td>
              <td class="px-6 py-4 text-center text-gray-500 dark:text-gray-400">10 min/session</td>
              <td class="px-6 py-4 text-center text-egc-600 dark:text-egc-400 font-semibold">0</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Security badges -->
    <section class="border-t border-gray-100 dark:border-gray-800 py-14">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-6">Security</p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="https://www.bestpractices.dev/projects/13099" target="_blank" rel="noopener noreferrer">
            <img src="https://www.bestpractices.dev/projects/13099/badge" alt="OpenSSF Best Practices" class="h-6" />
          </a>
          <a href="https://securityscorecards.dev/viewer/?uri=github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer">
            <img src="https://api.securityscorecards.dev/projects/github.com/Fmarzochi/EGC/badge" alt="OpenSSF Scorecard" class="h-6" />
          </a>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs font-medium">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            CodeQL enabled
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs font-medium">
