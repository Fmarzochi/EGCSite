---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Security" description="EGC security policy, OpenSSF badges, CodeQL, Dependabot, and vulnerability reporting." current="security">

  <div class="pb-2 mb-8 border-b border-gray-200">
    <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 mb-2">Reference</p>
    <h1 class="text-3xl font-bold text-gray-900 mb-3">Security</h1>
    <p class="text-gray-600">EGC follows OpenSSF Best Practices. All security-sensitive code is covered by CodeQL analysis and Dependabot.</p>
  </div>

  <!-- Badges -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Security posture</h2>
    <div class="flex flex-wrap gap-3 mb-6">
      <a href="https://www.bestpractices.dev/projects/13099" target="_blank" rel="noopener noreferrer">
        <img src="https://www.bestpractices.dev/projects/13099/badge" alt="OpenSSF Best Practices" class="h-6" />
      </a>
      <a href="https://securityscorecards.dev/viewer/?uri=github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer">
        <img src="https://api.securityscorecards.dev/projects/github.com/Fmarzochi/EGC/badge" alt="OpenSSF Scorecard" class="h-6" />
      </a>
    </div>
    <div class="grid sm:grid-cols-3 gap-4">
      {[
        { title: 'CodeQL', desc: 'Static analysis on every PR and weekly scheduled scans. Covers JavaScript and TypeScript.', icon: '🔍' },
        { title: 'Dependabot', desc: 'Automated dependency update PRs. Grouped by ecosystem (npm). Security alerts enabled.', icon: '🤖' },
        { title: 'OpenSSF Scorecard', desc: 'Weekly automated scoring. Checks branch protection, signed releases, CI, and more.', icon: '🏆' },
      ].map(card => (
        <div class="rounded-xl border border-gray-200 bg-white p-5">
          <div class="text-2xl mb-3">{card.icon}</div>
          <h3 class="font-semibold text-gray-900 text-sm mb-1">{card.title}</h3>
          <p class="text-xs text-gray-600">{card.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Reporting -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Reporting a vulnerability</h2>
    <div class="rounded-xl border border-red-200 bg-red-50 p-5 mb-5">
      <p class="text-sm text-red-800 font-semibold mb-1">Do not open public GitHub issues for security vulnerabilities.</p>
      <p class="text-sm text-red-700">Public disclosure before a fix is available puts all users at risk.</p>
    </div>
    <div class="space-y-3">
      <div class="flex items-start gap-3 rounded-xl border border-gray-200 bg-white p-4">
        <svg class="w-5 h-5 text-egc-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-gray-900 mb-1">Private GitHub Advisory</p>
          <a href="https://github.com/Fmarzochi/EGC/security/advisories/new" target="_blank" rel="noopener noreferrer" class="text-sm text-egc-600 hover:underline">github.com/Fmarzochi/EGC/security/advisories/new</a>
        </div>
      </div>
      <div class="flex items-start gap-3 rounded-xl border border-gray-200 bg-white p-4">
        <svg class="w-5 h-5 text-egc-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-gray-900 mb-1">Email</p>
          <a href="mailto:fmarzochi@gmail.com" class="text-sm text-egc-600 hover:underline">fmarzochi@gmail.com</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Response timeline</h2>
    <div class="space-y-2">
      {[
        { label: 'Acknowledgment', time: 'Within 72 hours' },
        { label: 'Status update', time: 'Within 14 days' },
        { label: 'Resolution or mitigation', time: 'Within 90 days of confirmed vulnerability' },
      ].map(row => (
        <div class="flex items-center justify-between rounded-xl border border-gray-200 bg-white px-5 py-3">
          <span class="text-sm font-medium text-gray-900">{row.label}</span>
          <span class="text-sm text-egc-600 font-semibold">{row.time}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Scope -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Scope</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="rounded-xl border border-egc-200 bg-egc-50 p-5">
        <h3 class="text-sm font-semibold text-egc-800 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          In scope
        </h3>
        <ul class="space-y-1.5 text-xs text-egc-700">
          {['scripts/', 'mcp/servers/', 'install.sh, install.ps1', 'hooks/, skills/'].map(s => (
            <li class="font-mono">{s}</li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-gray-200 bg-white p-5">
        <h3 class="text-sm font-semibold text-gray-600 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          Out of scope
        </h3>
        <ul class="space-y-1.5 text-xs text-gray-500">
          {[
            'Third-party dependency vulnerabilities',
            'Issues requiring physical machine access',
            'DoS against local-only runtime',
            'Behaviors requiring write access to host',
          ].map(s => (
            <li>{s}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

</DocsLayout>
