---
import DocsLayout from '../layouts/DocsLayout.astro';
---

<DocsLayout title="Features" description="Full feature overview: persistent memory, prompt library, multi-tool support, security, and more." current="features">

  <div class="pb-2 mb-8 border-b border-gray-200 dark:border-gray-800">
    <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-2">Getting Started</p>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-3">Features</h1>
    <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400">Everything EGC provides out of the box.</p>
  </div>

  <!-- Core features -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Core</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-4">
      {[
        { title: 'Persistent memory', desc: 'State is saved at the end of each session and restored at the start. Decisions, preferences, and next steps survive window closes and tool switches.', icon: '🧠' },
        { title: 'Global memory', desc: 'A user-wide scope shared across every project: save transversal preferences and lessons once with scope global, and every session in every tool starts already knowing them. Project state always wins.', icon: '🌍' },
        { title: 'Token Crusher', desc: 'Shell output is compressed up to 90% before it reaches the model: long git logs, test noise and install spam shrink while errors always survive. egc saved reports your accumulated savings at zero token cost.', icon: '⚡' },
        { title: 'Session Bus v2', desc: 'Parallel sessions announce presence, split territory, take fail-fast cooperative path locks, and now exchange events through a per-session queue, with live presence surfaced automatically on every memory read.', icon: '🚌' },
        { title: 'Commit privacy', desc: 'Populated memory never reaches a commit: pre-commit block, CI guard, and a git clean filter configured by egc init that stages a zeroed blob even when hooks are bypassed. Your context stays yours.', icon: '🔒' },
        { title: 'Bidirectional sync', desc: 'update_state propagates context to all 11 tool config files automatically. Run egc watch to also sync changes you make directly in any tool file back to state and to all other tools in real time.', icon: '🔄' },
        { title: 'Multi-tool', desc: 'Works with 20 AI coding tools. Install once and EGC registers itself in every tool you have installed.', icon: '🔌' },
        { title: 'Local-first', desc: 'All state stays on your machine at ~/.egc/, encrypted at rest with AES-256-GCM. Nothing is sent externally.', icon: '🔒' },
        { title: 'Zero config', desc: 'sh scripts/install.sh handles everything. Detects your tools, builds the servers, bootstraps the protocol.', icon: '⚡' },
        { title: 'Guardian layer', desc: 'egc-guardian enforces safety at the harness level: every shell command and file write is validated before execution. UserPromptSubmit and PreToolUse hooks block dangerous patterns without AI behavioral calls.', icon: '🛡️' },
        { title: 'Decision history', desc: 'Every architectural decision is stored in SQLite with a timestamp. Query by date or tag.', icon: '📋' },
      ].map(card => (
        <div class="flex gap-3 sm:gap-4 rounded-xl p-4 sm:p-5 glass hover-lift transition-all duration-300 min-h-[44px]">
          <div class="text-2xl shrink-0">{card.icon}</div>
          <div class="min-w-0">
            <h3 class="font-semibold text-gray-900 dark:text-white text-sm mb-1">{card.title}</h3>
            <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed break-words">{card.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Prompt library -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Prompt library</h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-5">Optional. Asked during installation. Written from real experience, not generated.</p>
    <!-- Desktop table -->
    <div class="hidden sm:block rounded-xl border border-gray-200 dark:border-gray-800 overflow-x-auto w-full mb-5">
      <table class="w-full text-sm min-w-[500px]">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
            <th scope="col" class="px-5 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Type</th>
            <th scope="col" class="px-5 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">Count</th>
            <th scope="col" class="px-5 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">What it is</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          {[
            { type: 'Agents', count: '63', desc: 'Persona and behavior definitions' },
            { type: 'Skills', count: '230', desc: 'Domain-specific workflow runbooks' },
            { type: 'Commands', count: '77', desc: 'Command definitions and lifecycle hooks' },
            { type: 'Rules', count: '111', desc: 'Constraints and governance directives' },
          ].map(row => (
            <tr class="bg-white dark:bg-gray-950">
              <td class="px-5 py-3 font-mono text-xs text-egc-700 dark:text-egc-400">{row.type}</td>
              <td class="px-5 py-3 text-center font-bold text-gray-900 dark:text-white">{row.count}</td>
              <td class="px-5 py-3 text-gray-600 dark:text-gray-400">{row.desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <!-- Mobile card layout -->
    <div class="sm:hidden space-y-3 mb-5">
      {[
        { type: 'Agents', count: '63', desc: 'Persona and behavior definitions' },
        { type: 'Skills', count: '230', desc: 'Domain-specific workflow runbooks' },
        { type: 'Commands', count: '77', desc: 'Command definitions and lifecycle hooks' },
        { type: 'Rules', count: '111', desc: 'Constraints and governance directives' },
      ].map(row => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 p-4 bg-white dark:bg-gray-950">
          <div class="flex items-center justify-between mb-1.5">
            <span class="font-mono text-xs font-semibold text-egc-700 dark:text-egc-400">{row.type}</span>
            <span class="font-bold text-sm text-gray-900 dark:text-white">{row.count}</span>
          </div>
          <p class="text-xs text-gray-600 dark:text-gray-400">{row.desc}</p>
        </div>
      ))}
    </div>
    <p class="text-sm text-gray-600 dark:text-gray-400">Organized per harness: works in <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono">.cursor/</code>, <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono">.claude/</code>, <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono">.gemini/</code>, and more. Switch tools and the same workflows follow you.</p>
  </section>

  <!-- Supported tools -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Supported tools</h2>
    <!-- Desktop table -->
    <div class="hidden sm:block rounded-xl border border-gray-200 dark:border-gray-800 overflow-x-auto w-full">
      <table class="w-full text-sm min-w-[500px]">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
            <th scope="col" class="px-5 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Tool</th>
            <th scope="col" class="px-5 py-3 text-center font-semibold text-gray-700 dark:text-gray-300">MCP</th>
            <th scope="col" class="px-5 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Bootstrap</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          {[
            { tool: 'Claude Code', mcp: true, bootstrap: '~/.claude/CLAUDE.md' },
            { tool: 'Antigravity CLI', mcp: true, bootstrap: '~/.gemini/GEMINI.md' },
            { tool: 'Gemini CLI', mcp: true, bootstrap: '~/.gemini/GEMINI.md' },
            { tool: 'Cursor', mcp: true, bootstrap: 'global cursor.rules' },
            { tool: 'Codex CLI', mcp: true, bootstrap: '~/.codex/config.toml' },
            { tool: 'OpenCode', mcp: true, bootstrap: '~/.opencode/instructions/EGC_MEMORY.md' },
            { tool: 'Windsurf', mcp: true, bootstrap: '~/.codeium/windsurf/' },
            { tool: 'Amp', mcp: true, bootstrap: '~/.amp/' },
            { tool: 'VS Code Copilot', mcp: true, bootstrap: '~/.github/' },
            { tool: 'Zed', mcp: true, bootstrap: '~/.config/zed/AGENTS.md' },
            { tool: 'Continue.dev', mcp: true, bootstrap: '~/.continue/mcpServers/' },
            { tool: 'Kiro', mcp: true, bootstrap: '~/.kiro/hooks/' },
            { tool: 'Trae', mcp: false, bootstrap: '~/.trae/MEMORY.md' },
            { tool: 'CodeBuddy', mcp: false, bootstrap: '~/.codebuddy/MEMORY.md' },
            { tool: 'JetBrains Junie', mcp: false, bootstrap: '.junie/guidelines.md' },
            { tool: 'Goose', mcp: false, bootstrap: '~/.agents/skills/' },
            { tool: 'Amazon Q Developer', mcp: false, bootstrap: '.amazonq/rules/' },
            { tool: 'OpenHands', mcp: false, bootstrap: '~/.agents/skills/' },
            { tool: 'Aider', mcp: false, bootstrap: '.aider/skills/ + .aider.conf.yml' },
            { tool: 'Warp', mcp: false, bootstrap: '.warp/skills/ + AGENTS.md index' },
          ].map(row => (
            <tr class="bg-white dark:bg-gray-950">
              <td class="px-5 py-3 font-medium text-gray-900 dark:text-white">{row.tool}</td>
              <td class="px-5 py-3 text-center">
                {row.mcp
                  ? <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-egc-100 dark:bg-egc-900/30" aria-label="Yes"><svg class="w-3 h-3 text-egc-600 dark:text-egc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg></span>
                  : <span class="text-xs text-gray-400 dark:text-gray-300">context</span>
                }
              </td>
              <td class="px-5 py-3 font-mono text-xs text-gray-500 dark:text-gray-400">{row.bootstrap}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <!-- Mobile card layout -->
    <div class="sm:hidden space-y-3">
      {[
        { tool: 'Claude Code', mcp: true, bootstrap: '~/.claude/CLAUDE.md' },
        { tool: 'Antigravity CLI', mcp: true, bootstrap: '~/.gemini/GEMINI.md' },
        { tool: 'Gemini CLI', mcp: true, bootstrap: '~/.gemini/GEMINI.md' },
        { tool: 'Cursor', mcp: true, bootstrap: 'global cursor.rules' },
        { tool: 'Codex CLI', mcp: true, bootstrap: '~/.codex/config.toml' },
        { tool: 'OpenCode', mcp: true, bootstrap: '~/.opencode/instructions/EGC_MEMORY.md' },
        { tool: 'Windsurf', mcp: true, bootstrap: '~/.codeium/windsurf/' },
        { tool: 'Amp', mcp: true, bootstrap: '~/.amp/' },
        { tool: 'VS Code Copilot', mcp: true, bootstrap: '~/.github/' },
        { tool: 'Zed', mcp: true, bootstrap: '~/.config/zed/AGENTS.md' },
        { tool: 'Continue.dev', mcp: true, bootstrap: '~/.continue/mcpServers/' },
        { tool: 'Kiro', mcp: true, bootstrap: '~/.kiro/hooks/' },
        { tool: 'Trae', mcp: false, bootstrap: '~/.trae/MEMORY.md' },
        { tool: 'CodeBuddy', mcp: false, bootstrap: '~/.codebuddy/MEMORY.md' },
        { tool: 'JetBrains Junie', mcp: false, bootstrap: '.junie/guidelines.md' },
        { tool: 'Goose', mcp: false, bootstrap: '~/.agents/skills/' },
        { tool: 'Amazon Q Developer', mcp: false, bootstrap: '.amazonq/rules/' },
        { tool: 'OpenHands', mcp: false, bootstrap: '~/.agents/skills/' },
        { tool: 'Aider', mcp: false, bootstrap: '.aider/skills/ + .aider.conf.yml' },
        { tool: 'Warp', mcp: false, bootstrap: '.warp/skills/ + AGENTS.md index' },
      ].map(row => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 p-4 bg-white dark:bg-gray-950">
          <div class="flex items-center justify-between mb-1.5">
            <span class="font-medium text-sm text-gray-900 dark:text-white">{row.tool}</span>
            {row.mcp
              ? <span class="inline-flex items-center gap-1 text-[10px] font-bold uppercase px-1.5 py-0.5 rounded-full bg-egc-100 dark:bg-egc-900/30 text-egc-700 dark:text-egc-400">MCP</span>
              : <span class="inline-flex items-center gap-1 text-[10px] font-bold uppercase px-1.5 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">context</span>
            }
          </div>
          <p class="font-mono text-xs text-gray-500 dark:text-gray-400 break-all">{row.bootstrap}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Supported LLM providers -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Supported LLM providers</h2>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-5">EGC routes to any supported provider via <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono">ModelResolver</code>. Fallback chains degrade automatically when a model is unavailable.</p>
    <div class="hidden sm:block rounded-xl border border-gray-200 dark:border-gray-800 overflow-x-auto w-full">
      <table class="w-full text-sm min-w-[500px]">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
            <th scope="col" class="px-5 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Provider</th>
            <th scope="col" class="px-5 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Models</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          {[
            { provider: 'Google Gemini', models: 'Gemini 2.5 Pro / Flash / Flash-Lite, 2.0 Flash, 1.5 Pro / Flash' },
            { provider: 'Anthropic Claude', models: 'Opus 4.5, Sonnet 4.7, Haiku 4.7' },
            { provider: 'OpenAI', models: 'GPT-4o, GPT-4o-mini' },
            { provider: 'OpenRouter', models: 'DeepSeek R1, DeepSeek Chat V3, Qwen3 235B, Qwen3 32B, Llama 4 Maverick, Llama 4 Scout, Llama 3.3 70B, Gemini 2.5 via OR, GPT-4o via OR, and more' },
            { provider: 'Ollama', models: 'Llama 3.2 (local, offline)' },
          ].map(row => (
            <tr class="bg-white dark:bg-gray-950">
              <td class="px-5 py-3 font-medium text-gray-900 dark:text-white whitespace-nowrap">{row.provider}</td>
              <td class="px-5 py-3 text-gray-600 dark:text-gray-400 text-xs">{row.models}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="sm:hidden space-y-3">
      {[
        { provider: 'Google Gemini', models: 'Gemini 2.5 Pro / Flash / Flash-Lite, 2.0 Flash, 1.5 Pro / Flash' },
        { provider: 'Anthropic Claude', models: 'Opus 4.5, Sonnet 4.7, Haiku 4.7' },
        { provider: 'OpenAI', models: 'GPT-4o, GPT-4o-mini' },
        { provider: 'OpenRouter', models: 'DeepSeek R1, DeepSeek Chat V3, Qwen3 235B, Qwen3 32B, Llama 4 Maverick, Llama 4 Scout, Llama 3.3 70B, and more' },
        { provider: 'Ollama', models: 'Llama 3.2 (local, offline)' },
      ].map(row => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 p-4 bg-white dark:bg-gray-950">
          <p class="font-medium text-sm text-gray-900 dark:text-white mb-1">{row.provider}</p>
          <p class="text-xs text-gray-600 dark:text-gray-400">{row.models}</p>
        </div>
      ))}
    </div>
  </section>

</DocsLayout>
