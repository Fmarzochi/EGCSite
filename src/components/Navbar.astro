---
const b = import.meta.env.BASE_URL;
const base = b.endsWith('/') ? b : b + '/';
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}get-started`, label: 'Get Started' },
  { href: `${base}features`, label: 'Features' },
  { href: `${base}docs/memory`, label: 'Docs' },
  { href: 'https://github.com/Fmarzochi/EGC', label: 'GitHub', external: true },
];
---

<header id="site-header" class="sticky top-0 z-50 w-full border-b border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-950/90 backdrop-blur-md transition-transform duration-300 transform translate-y-0">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">

      <div class="flex items-center gap-6">
        <a href={base} class="flex items-center gap-2">
          <img src={`${base}egc-logo.png`} alt="EGC Logo" class="h-6 w-6 object-contain" />
          <span class="font-bold text-sm tracking-tight text-gray-900 dark:text-white">EGC</span>
        </a>

        <nav class="hidden md:flex items-center gap-1">
          {navLinks.map(link => (
            <a
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
              class="px-3 py-1.5 rounded-md text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-150"
            >
              {link.label}
              {link.external && (
                <svg class="inline-block ml-0.5 w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              )}
            </a>
          ))}
        </nav>
      </div>

      <div class="flex items-center gap-2">
        <a
          href="https://github.com/Fmarzochi/EGC"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-900 dark:bg-white text-white dark:text-gray-900 text-xs font-semibold hover:bg-gray-700 dark:hover:bg-gray-100 transition-colors duration-150"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>

        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="md:hidden p-3 min-w-[44px] min-h-[44px] flex items-center justify-center rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-egc-500 active:scale-95 active:bg-gray-200 dark:active:bg-gray-800 transition-all duration-100"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path class="line-1" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16"/>
            <path class="line-2" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12h16"/>
            <path class="line-3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-4 shadow-lg transition-[max-height,opacity,visibility] duration-300 ease-in-out overflow-hidden max-h-0 opacity-0 pointer-events-none invisible">
    <nav class="flex flex-col gap-1.5 py-3">
      {navLinks.map(link => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class="flex items-center min-h-[44px] px-3 py-2 rounded-md text-base font-medium text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 hover:bg-gray-50 dark:hover:bg-gray-900 active:scale-[0.98] active:bg-gray-100 dark:active:bg-gray-800 transition-all duration-100"
        >
          {link.label}
          {link.external && (
            <svg class="inline-block ml-1.5 w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          )}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    const isExpanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
    mobileMenuBtn.setAttribute('aria-expanded', String(!isExpanded));
    
    if (isExpanded) {
      mobileMenu?.classList.add('max-h-0', 'opacity-0', 'pointer-events-none', 'invisible');
      mobileMenu?.classList.remove('max-h-[400px]', 'opacity-100', 'pointer-events-auto', 'visible');
    } else {
      mobileMenu?.classList.remove('max-h-0', 'opacity-0', 'pointer-events-none', 'invisible');
      mobileMenu?.classList.add('max-h-[400px]', 'opacity-100', 'pointer-events-auto', 'visible');
    }
  });

  // Scroll dynamics
  let lastScrollY = window.scrollY;
  let scrollTimeout: NodeJS.Timeout | undefined;
  const header = document.getElementById('site-header');

  if (header) {
    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;
      
      // Clear timeout for detecting scroll stop
      if (scrollTimeout) clearTimeout(scrollTimeout);
      
      if (currentScrollY > 64) {
        if (currentScrollY > lastScrollY) {
          // Scrolling down -> hide header
          header.classList.add('-translate-y-full');
          header.classList.remove('translate-y-0');
        } else {
          // Scrolling up -> show header
          header.classList.add('translate-y-0');
          header.classList.remove('-translate-y-full');
        }
      } else {
        // At the top -> always show
        header.classList.add('translate-y-0');
        header.classList.remove('-translate-y-full');
      }
      
      lastScrollY = currentScrollY;
      
      // Scroll stop detection: reveal header after 250ms of inactivity
      scrollTimeout = setTimeout(() => {
        header.classList.add('translate-y-0');
        header.classList.remove('-translate-y-full');
      }, 250);
    }, { passive: true });
  }
</script>

<style>
  .line-1, .line-2, .line-3 {
    transform-origin: center;
    transition: transform 0.2s ease-in-out, opacity 0.15s ease-in-out;
  }
  #mobile-menu-btn[aria-expanded="true"] .line-1 {
    transform: translateY(6px) rotate(45deg);
  }
  #mobile-menu-btn[aria-expanded="true"] .line-2 {
    opacity: 0;
  }
  #mobile-menu-btn[aria-expanded="true"] .line-3 {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>
