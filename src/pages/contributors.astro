---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getBase } from '../utils/base.ts';
const base = getBase();

const OWNER = 'Fmarzochi';
const REPO = 'EGC';
const EXCLUDED = new Set([OWNER, 'dependabot[bot]', 'github-actions[bot]']);

const highlights: Record<string, { name: string; highlight: string; since: string }> = {
  Kunall7890:           { name: 'Kunal Jaiswal',      highlight: 'Zed editor support, compress_observations MCP tool, Windows dashboard fix', since: 'Jun 11, 2026' },
  gaoflow:              { name: 'Vincent Gao',         highlight: 'Fixed critical bugs across all AI providers in a single day',               since: 'Jun 22, 2026' },
  muhammadhasnain3031:  { name: 'Muhammad Husnain',    highlight: 'OpenRouter model mappings, Arabic and Hindi README translations',            since: 'Jun 19, 2026' },
  'NITESH-DTU':         { name: 'Nitesh Kumar',        highlight: 'Fixed two critical egc-memory bugs back to back',                           since: 'Jun 16, 2026' },
  'vasu-sachdeva':      { name: 'Vasu Sachdeva',       highlight: 'Null safety fixes across Claude and Ollama providers',                      since: 'Jun 23, 2026' },
  shekar50:             { name: 'Shekar',               highlight: 'Usage analytics heatmap for the dashboard',                                 since: 'Jun 25, 2026' },
  shantoshdurai:        { name: 'Santosh Durai',        highlight: 'Added --version/-v flag to the EGC CLI',                                    since: 'Jun 10, 2026' },
  koteshyelamati:       { name: 'Kotesh Yelamati',      highlight: 'Windows HOME/USERPROFILE environment variable fix',                         since: 'Jun 17, 2026' },
  lesbass:              { name: 'Stefano Maffeis',      highlight: 'JSONDecodeError fix in OpenAI and OpenRouter providers',                    since: 'Jun 22, 2026' },
  'srivastava-prakhar': { name: 'Prakhar Srivastava',   highlight: 'Narrowed overly broad exception handling in model selector',               since: 'Jun 23, 2026' },
  ayushikaul02:         { name: 'Ayushi Kaul',          highlight: 'Co-authored fix for bare except in Gemini provider',                       since: 'Jun 22, 2026' },
  krishna3554:          { name: 'Krishna Lokhande',     highlight: 'Co-authored fix for AttributeError in Claude provider',                    since: 'Jun 22, 2026' },
  vaishnavidesai09:     { name: 'Vaishnavi Desai',      highlight: 'Co-authored Ollama usage token fix in the provider layer',                 since: 'Jun 22, 2026' },
};

type Contributor = {
  login: string;
  name: string;
  avatar: string;
  commits: number;
  additions: number;
  highlight: string;
  since: string;
};

async function fetchContributors(): Promise<Contributor[]> {
  const headers: Record<string, string> = { Accept: 'application/vnd.github+json' };
  const token = import.meta.env.GITHUB_TOKEN;
  if (token) headers['Authorization'] = `Bearer ${token}`;

  const statsRes = await fetch(
    `https://api.github.com/repos/${OWNER}/${REPO}/stats/contributors`,
    { headers }
  );

  if (statsRes.status === 202 || !statsRes.ok) throw new Error('GitHub API not ready');

  const statsData = await statsRes.json() as {
    author: { login: string; avatar_url: string };
    total: number;
    weeks: { a: number; d: number; c: number }[];
  }[];

  const result = statsData
    .filter(c => !EXCLUDED.has(c.author.login) && !c.author.login.includes('[bot]'))
    .sort((a, b) => b.total - a.total)
    .map(c => {
      const additions = c.weeks.reduce((sum, w) => sum + w.a, 0);
      const info = highlights[c.author.login];
      return {
        login: c.author.login,
        name: info?.name ?? c.author.login,
        avatar: `https://github.com/${c.author.login}.png`,
        commits: c.total,
        additions,
        highlight: info?.highlight ?? 'Contributed to EGC',
        since: info?.since ?? '',
      };
    });

  if (result.length === 0) throw new Error('Empty contributor list');
  return result;
}

let contributors: Contributor[] = [];
try {
  contributors = await fetchContributors();
} catch {
  contributors = Object.entries(highlights).map(([login, info]) => ({
    login,
    name: info.name,
    avatar: `https://github.com/${login}.png`,
    commits: 0,
    additions: 0,
    highlight: info.highlight,
    since: info.since,
  }));
}

const topThree = contributors.slice(0, 3);
const rest = contributors.slice(3);
---

<Base
  title="Top Contributors -- EGC"
  description="The developers who built EGC together. Every pull request, every bug report, every translation counts."
>
  <Navbar />

  <main id="main-content">

    <!-- Hero -->
    <section class="relative overflow-hidden py-16 sm:py-24">
      <div class="absolute inset-0 pointer-events-none -z-10" aria-hidden="true">
        <div class="absolute left-1/4 top-0 w-[500px] h-[400px] bg-egc-500/10 rounded-full blur-[100px] mix-blend-screen"></div>
        <div class="absolute right-1/4 bottom-0 w-[400px] h-[300px] bg-yellow-400/8 rounded-full blur-[100px] mix-blend-screen"></div>
      </div>

      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">

        <!-- Icon + badge -->
        <div class="flex items-center justify-center mb-6">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl glass shadow-lg">
            <svg class="w-8 h-8 text-yellow-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17 5.8 21.3l2.4-7.4L2 9.4h7.6L12 2z"/>
            </svg>
          </div>
        </div>

        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-white mb-4">
          Top Contributors
        </h1>
        <p class="text-base sm:text-lg text-gray-400 max-w-xl mx-auto mb-8">
          EGC is built by developers like you. Every pull request, every bug fix, every translation is here permanently.
        </p>

        <!-- Stats row -->
        <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10 mb-4">
          {[
            { value: String(contributors.length), label: 'Contributors' },
            { value: String(contributors.reduce((s, c) => s + c.commits, 0)), label: 'Commits' },
            { value: `+${contributors.reduce((s, c) => s + c.additions, 0).toLocaleString('en')}`, label: 'Lines added' },
          ].map(s => (
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-extrabold text-egc-400">{s.value}</div>
              <div class="text-xs text-gray-500 uppercase tracking-widest mt-1">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Podium: top 3 -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-12">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {topThree.map((c, i) => (
          <a
            href={`https://github.com/${c.login}`}
            target="_blank"
            rel="noopener noreferrer"
            class={`group relative rounded-2xl p-6 flex flex-col items-center text-center glass hover-lift transition-all duration-300 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500 ${i === 0 ? 'ring-2 ring-yellow-400/40' : ''}`}
          >
            <!-- Rank badge -->
            <div class={`absolute -top-3 left-1/2 -translate-x-1/2 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shadow-lg ${i === 0 ? 'bg-yellow-400 text-gray-900' : i === 1 ? 'bg-gray-300 text-gray-900' : 'bg-amber-600 text-white'}`}>
              {i + 1}
            </div>

            <img
              src={c.avatar}
              alt={c.name}
              width="72"
              height="72"
              class={`rounded-full mb-4 mt-2 ring-2 transition-all duration-200 ${i === 0 ? 'ring-yellow-400/60 group-hover:ring-yellow-400' : 'ring-gray-700 group-hover:ring-egc-500'}`}
              loading="lazy"
            />

            <p class="font-bold text-white text-sm mb-0.5">{c.name}</p>
            <p class="text-xs text-gray-500 mb-3">@{c.login}</p>

            <div class="flex items-center gap-3 mb-4">
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-egc-900/60 text-egc-400 text-xs font-semibold">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {c.commits} commit{c.commits !== 1 ? 's' : ''}
              </span>
              {c.additions > 0 && (
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-gray-800/60 text-gray-400 text-xs font-semibold">
                  +{c.additions}
                </span>
              )}
            </div>

            <p class="text-xs text-gray-500 leading-relaxed">{c.highlight}</p>

            <p class="text-xs text-gray-600 mt-3">Since {c.since}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- All contributors grid -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-16">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-6">All contributors</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {rest.map(c => (
          <a
            href={`https://github.com/${c.login}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 rounded-xl p-4 glass hover-lift transition-all duration-200 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500"
          >
            <img
              src={c.avatar}
              alt={c.name}
              width="48"
              height="48"
              class="rounded-full ring-2 ring-transparent group-hover:ring-egc-500 transition-all duration-200 shrink-0"
              loading="lazy"
            />
            <div class="min-w-0">
              <p class="font-semibold text-white text-sm truncate">{c.name}</p>
              <p class="text-xs text-gray-500 mb-1">@{c.login}</p>
              <p class="text-xs text-gray-500 leading-snug truncate">{c.highlight}</p>
            </div>
            <div class="ml-auto shrink-0 text-right">
              <span class="block text-xs font-bold text-egc-400">{c.commits > 0 ? `${c.commits} commit${c.commits !== 1 ? 's' : ''}` : 'co-author'}</span>
              {c.additions > 0 && <span class="block text-xs text-gray-600">+{c.additions}</span>}
            </div>
          </a>
        ))}
      </div>

      <!-- CTA: become a contributor -->
      <div class="mt-8 rounded-2xl p-6 sm:p-8 text-center glass hover-glow">
        <p class="text-sm text-gray-400 mb-4">
          Want your name on this page? Find an open issue and ship a fix.
        </p>
        <a
          href="https://github.com/Fmarzochi/EGC/issues"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-egc-600 hover:bg-egc-500 text-white text-sm font-semibold transition-colors duration-200 active:scale-95"
        >
          Browse open issues
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </section>

    <!-- Sponsors -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20">

      <div class="relative rounded-2xl p-6 sm:p-10 glass hover-glow overflow-hidden">
        <div class="absolute inset-0 pointer-events-none -z-10" aria-hidden="true">
          <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[300px] bg-pink-500/10 rounded-full blur-[80px] mix-blend-screen"></div>
        </div>

        <!-- Header -->
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-10">
          <div class="text-center sm:text-left">
            <div class="flex items-center justify-center sm:justify-start gap-2 mb-1">
              <svg class="w-5 h-5 text-pink-500 animate-heartbeat" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 21.593c-.317.177-.834.177-1.151 0C9.774 20.57 3 16.259 3 9.5 3 6.462 5.462 4 8.5 4c1.4 0 2.672.536 3.5 1.393C12.828 4.536 14.1 4 15.5 4 18.538 4 21 6.462 21 9.5c0 6.759-6.774 11.07-9 12.093z"/>
              </svg>
              <h2 class="text-lg font-bold text-white">Sponsors</h2>
            </div>
            <p class="text-xs text-gray-500 max-w-xs">EGC is free and open source. Sponsors keep it alive and moving forward.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-2 shrink-0">
            <a
              href="https://github.com/sponsors/Fmarzochi"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center gap-2 min-h-[40px] px-4 py-2 rounded-xl border border-gray-700 bg-gray-900 text-gray-300 text-sm font-semibold hover:border-pink-700 hover:text-pink-400 active:scale-95 transition-all duration-200"
            >
              <svg class="w-4 h-4 text-pink-500/70 group-hover:text-pink-400 transition-colors animate-heartbeat" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21.593c-.317.177-.834.177-1.151 0C9.774 20.57 3 16.259 3 9.5 3 6.462 5.462 4 8.5 4c1.4 0 2.672.536 3.5 1.393C12.828 4.536 14.1 4 15.5 4 18.538 4 21 6.462 21 9.5c0 6.759-6.774 11.07-9 12.093z"/></svg>
              GitHub Sponsors
            </a>
            <a
              href="https://www.paypal.com/donate/?business=fmarzochi%40gmail.com&currency_code=USD"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center gap-2 min-h-[40px] px-4 py-2 rounded-xl border border-gray-700 bg-gray-900 text-gray-300 text-sm font-semibold hover:border-blue-700 hover:text-blue-400 active:scale-95 transition-all duration-200"
            >
              <svg class="w-4 h-4 text-blue-500/70 group-hover:text-blue-400 transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516a.56.56 0 0 0 .554.647h3.882c.46 0 .85-.334.922-.788.06-.26.76-4.852.816-5.09a.932.932 0 0 1 .923-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"/></svg>
              PayPal
            </a>
          </div>
        </div>

        <!-- Monthly sponsors -->
        <div class="mb-8">
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4">Monthly sponsors</p>
          <p class="text-xs text-gray-600 italic">Be the first monthly sponsor.</p>
        </div>

        <!-- One-time backers -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4">Backers</p>
          <div class="flex flex-wrap gap-3">
            <a
              href="https://github.com/chizormaangel-commits"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="@chizormaangel-commits on GitHub (opens in new tab)"
              class="group relative focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500 rounded-full"
            >
              <img
                src="https://avatars.githubusercontent.com/u/291871326?v=4"
                alt="@chizormaangel-commits"
                width="52"
                height="52"
                class="rounded-full ring-2 ring-transparent group-hover:ring-pink-400 transition-all duration-200"
                loading="lazy"
              />
            </a>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Base>
