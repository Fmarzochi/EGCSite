---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="Security" description="EGC security posture: OpenSSF, CodeQL, SonarCloud, Socket.dev supply chain, Dependency Review, ClusterFuzzLite, Dependabot, and vulnerability reporting." current="security">

  <div class="pb-2 mb-8 border-b border-gray-200 dark:border-gray-800">
    <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-2">Reference</p>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-3">Security</h1>
    <p class="text-gray-600 dark:text-gray-400">EGC maintains a layered security posture: static analysis, supply chain protection, continuous fuzzing, and community-driven scoring.</p>
  </div>

  <!-- Badges -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Security posture</h2>
    <div class="flex flex-wrap gap-3 mb-6">
      <a href="https://www.bestpractices.dev/projects/13099" target="_blank" rel="noopener noreferrer" aria-label="OpenSSF Best Practices (opens in new tab)">
        <img src="https://www.bestpractices.dev/projects/13099/badge" alt="OpenSSF Best Practices" class="h-6" />
      </a>
      <a href="https://securityscorecards.dev/viewer/?uri=github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer" aria-label="OpenSSF Scorecard (opens in new tab)">
        <img src="https://img.shields.io/ossf-scorecard/github.com/Fmarzochi/EGC?label=openssf+scorecard&style=flat" alt="OpenSSF Scorecard" class="h-6" />
      </a>
      <a href="https://sonarcloud.io/project/overview?id=Fmarzochi_EGC" target="_blank" rel="noopener noreferrer" aria-label="SonarCloud quality gate (opens in new tab)">
        <img src="https://sonarcloud.io/api/project_badges/measure?project=Fmarzochi_EGC&metric=alert_status" alt="SonarCloud Quality Gate" class="h-6" />
      </a>
      <a href="https://github.com/Fmarzochi/EGC/actions/workflows/codeql.yml" target="_blank" rel="noopener noreferrer" aria-label="CodeQL status (opens in new tab)">
        <img src="https://img.shields.io/github/actions/workflow/status/Fmarzochi/EGC/codeql.yml?branch=main&label=CodeQL&logo=github&style=flat" alt="CodeQL" class="h-6" />
      </a>
      <a href="https://socket.dev/npm/package/@egchq/egc" target="_blank" rel="noopener noreferrer" aria-label="Socket.dev supply chain score (opens in new tab)">
        <img src="https://socket.dev/api/badge/npm/package/@egchq/egc" alt="Socket" class="h-6" />
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        {
          title: 'CodeQL',
          icon: '🔍',
          desc: 'Static analysis on every PR and weekly scheduled scans. Covers JavaScript and TypeScript. Advanced query suite enabled.',
          href: 'https://github.com/Fmarzochi/EGC/actions/workflows/codeql.yml',
        },
        {
          title: 'SonarCloud',
          icon: '☁️',
          desc: 'Continuous code quality and security analysis. Tracks reliability, maintainability, and security hotspots on every push.',
          href: 'https://sonarcloud.io/project/overview?id=Fmarzochi_EGC',
        },
        {
          title: 'Dependabot',
          icon: '🤖',
          desc: 'Automated dependency update PRs. Grouped by ecosystem (npm). Security alerts and auto-dismissal of dev-only patches enabled.',
          href: 'https://github.com/Fmarzochi/EGC/network/updates',
        },
        {
          title: 'Dependency Review',
          icon: '🔗',
          desc: 'Every PR is scanned for newly introduced vulnerable or license-incompatible dependencies before merge.',
          href: 'https://github.com/Fmarzochi/EGC/actions/workflows/dependency-review.yml',
        },
        {
          title: 'ClusterFuzzLite',
          icon: '💥',
          desc: 'Continuous fuzzing via ClusterFuzzLite on every PR, batch runs, and weekly scheduled cron jobs. Catches memory and logic bugs.',
          href: 'https://github.com/Fmarzochi/EGC/actions/workflows/fuzzing.yml',
        },
        {
          title: 'OpenSSF Scorecard',
          icon: '🏆',
          desc: 'Weekly automated scoring across 20+ security checks: branch protection, signed releases, CI, token permissions, and more.',
          href: 'https://securityscorecards.dev/viewer/?uri=github.com/Fmarzochi/EGC',
        },
        {
          title: 'OpenSSF Best Practices',
          icon: '✅',
          desc: 'CII Best Practices badge achieved. Validates documentation, test coverage, vulnerability reporting process, and project hygiene.',
          href: 'https://www.bestpractices.dev/projects/13099',
        },
        {
          title: 'Socket.dev',
          icon: '🧦',
          desc: 'Supply chain protection on every PR touching package.json. Catches malicious packages, typosquatting, and obfuscated code before they reach the codebase.',
          href: 'https://socket.dev/npm/package/@egchq/egc',
        },
        {
          title: 'DCO',
          icon: '✍️',
          desc: 'Developer Certificate of Origin enforced on every commit. All contributors must sign off their changes.',
          href: 'https://github.com/Fmarzochi/EGC/actions/workflows/dco.yml',
        },
      ].map(card => (
        <a
          href={card.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5 hover:border-egc-500/50 dark:hover:border-egc-500/30 transition-colors"
        >
          <div class="text-2xl mb-3">{card.icon}</div>
          <h3 class="font-semibold text-gray-900 dark:text-white text-sm mb-1 group-hover:text-egc-600 dark:group-hover:text-egc-400 transition-colors">{card.title}</h3>
          <p class="text-xs text-gray-600 dark:text-gray-400">{card.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Reporting -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Reporting a vulnerability</h2>
    <div class="rounded-xl border border-red-200 dark:border-red-900/50 bg-red-50 dark:bg-red-950/20 p-5 mb-5">
      <p class="text-sm text-red-800 dark:text-red-300 font-semibold mb-1">Do not open public GitHub issues for security vulnerabilities.</p>
      <p class="text-sm text-red-700 dark:text-red-400">Public disclosure before a fix is available puts all users at risk.</p>
    </div>
    <div class="space-y-3">
      <div class="flex items-start gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4">
        <svg class="w-5 h-5 text-egc-600 dark:text-egc-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Private GitHub Advisory</p>
          <a href="https://github.com/Fmarzochi/EGC/security/advisories/new" target="_blank" rel="noopener noreferrer" class="text-sm text-egc-600 dark:text-egc-400 hover:underline">github.com/Fmarzochi/EGC/security/advisories/new</a>
        </div>
      </div>
      <div class="flex items-start gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4">
        <svg class="w-5 h-5 text-egc-600 dark:text-egc-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-gray-900 dark:text-white mb-1">Email</p>
          <a href="mailto:fmarzochi@gmail.com" class="text-sm text-egc-600 dark:text-egc-400 hover:underline">fmarzochi@gmail.com</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Response timeline</h2>
    <div class="space-y-2">
      {[
        { label: 'Acknowledgment', time: 'Within 72 hours' },
        { label: 'Status update', time: 'Within 14 days' },
        { label: 'Resolution or mitigation', time: 'Within 90 days of confirmed vulnerability' },
      ].map(row => (
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 sm:gap-4 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 px-4 sm:px-5 py-3">
          <span class="text-sm font-medium text-gray-900 dark:text-white">{row.label}</span>
          <span class="text-sm text-egc-600 dark:text-egc-400 font-semibold">{row.time}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Scope -->
  <section class="mb-10">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Scope</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="rounded-xl border border-egc-200 dark:border-egc-900 bg-egc-50 dark:bg-egc-950/20 p-5">
        <h3 class="text-sm font-semibold text-egc-800 dark:text-egc-300 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          In scope
        </h3>
        <ul class="space-y-1.5 text-xs text-egc-700 dark:text-egc-400">
          {['scripts/', 'mcp/servers/', 'install.sh, install.ps1', 'hooks/, skills/'].map(s => (
            <li class="font-mono">{s}</li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-5">
        <h3 class="text-sm font-semibold text-gray-600 dark:text-gray-400 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
          Out of scope
        </h3>
        <ul class="space-y-1.5 text-xs text-gray-500 dark:text-gray-500">
          {[
            'Third-party dependency vulnerabilities',
            'Issues requiring physical machine access',
            'DoS against local-only runtime',
            'Behaviors requiring write access to host',
          ].map(s => (
            <li>{s}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

</DocsLayout>
