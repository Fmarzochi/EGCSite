---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const b = import.meta.env.BASE_URL;
const base = b.endsWith('/') ? b : b + '/';
---

<Base title="EGC - Extended Global Context" description="Your AI remembers your project across sessions and tools. Persistent memory and shared context for every AI coding tool.">
  <Navbar />

  <main id="main-content">
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gray-50 dark:bg-gray-950 pt-24 pb-20 sm:pt-32 sm:pb-28">
      <!-- Grid pattern for glassmorphism refraction -->
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMTI4LDEyOCwxMjgsMC4yKSIvPjwvc3ZnPg==')] dark:bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiLz48L3N2Zz4=')] [mask-image:linear-gradient(to_bottom,white,transparent)] z-0"></div>

      <!-- Glow Orbs using standard Tailwind classes to ensure they compile -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden flex justify-center z-0" aria-hidden="true">
        <div class="w-[500px] h-[500px] bg-egc-500/40 dark:bg-egc-500/30 blur-3xl rounded-full absolute top-[-100px] left-0 md:left-[20%] mix-blend-screen"></div>
        <div class="w-[400px] h-[400px] bg-blue-500/30 dark:bg-blue-500/20 blur-3xl rounded-full absolute top-[50px] right-0 md:right-[20%] mix-blend-screen"></div>
      </div>
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center relative z-10">
        <div class="flex flex-wrap items-center justify-center gap-3 mb-8 sm:mb-10">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-egc-700 dark:text-egc-300 text-xs font-medium glass hover-glow transition-all">
            <span class="w-2 h-2 rounded-full bg-egc-500 shadow-[0_0_8px_#22c55e] animate-pulse"></span>
            v1.0.1 now available
            <a href="https://github.com/Fmarzochi/EGC/releases" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-egc-600 dark:hover:text-egc-400">See release</a>
          </div>
          <a href="https://github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-gray-700 dark:text-gray-100 text-xs font-medium hover:bg-black/5 dark:hover:bg-white/5 transition-all glass hover-lift">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Fmarzochi/EGC
          </a>
        </div>

        <h1 class="text-2xl sm:text-4xl lg:text-6xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-4 sm:mb-6 leading-tight animate-fade-in-up text-balance">
          Your AI remembers your<br class="hidden sm:block" />
          <span class="text-egc-600 dark:text-egc-400 gradient-text">project across sessions</span><br class="hidden sm:block" />
          and tools.
        </h1>

        <p class="mx-auto max-w-2xl text-base sm:text-lg text-gray-600 dark:text-gray-400 mb-6 sm:mb-8 leading-relaxed animate-fade-in-up animate-fade-in-up-delay-1 text-pretty">
          EGC is an open-source runtime that gives every AI coding tool a shared, persistent memory of your project. Install once, works everywhere.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-8 sm:mb-10 px-4 sm:px-0 animate-fade-in-up animate-fade-in-up-delay-2">
          <a href={`${base}get-started`} class="w-full sm:w-auto inline-flex items-center justify-center gap-2 min-h-[48px] px-6 py-3 rounded-xl bg-egc-600 text-white font-semibold hover:bg-egc-700 active:scale-95 transition-all duration-100 focus:outline-none focus:ring-2 focus:ring-egc-500 focus:ring-offset-2">
            Get Started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a href="https://github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 min-h-[48px] px-6 py-3 rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-700 dark:text-gray-300 font-semibold hover:bg-gray-50 dark:hover:bg-gray-800 active:scale-95 transition-all duration-100">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            GitHub
          </a>
        </div>

        <div class="max-w-xl mx-auto mt-12 sm:mt-16 rounded-2xl overflow-hidden shadow-2xl shadow-egc-500/20 animate-fade-in-up animate-fade-in-up-delay-3 glass hover-glow relative z-10">
          <div class="flex items-center gap-2 px-4 py-3 bg-white/10 dark:bg-white/5 border-b border-black/10 dark:border-white/10 backdrop-blur-2xl">
            <span class="w-3 h-3 rounded-full bg-red-500/90 shadow-sm"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/90 shadow-sm"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/90 shadow-sm"></span>
            <span class="ml-2 text-xs text-gray-600 dark:text-gray-400 font-mono">terminal</span>
          </div>
          <div class="p-4 sm:p-6 text-left font-mono text-xs sm:text-sm text-gray-800 dark:text-gray-100 leading-relaxed overflow-hidden relative min-h-[220px] sm:min-h-[260px]" tabindex="0" role="region" aria-label="Terminal installation steps simulation">
            <!-- Terminal Skeleton Loader -->
            <div id="terminal-skeleton" class="space-y-3 animate-pulse py-2">
              <div class="h-4 bg-gray-300/50 dark:bg-gray-700/50 rounded w-2/3"></div>
              <div class="h-4 bg-gray-300/50 dark:bg-gray-700/50 rounded w-1/2"></div>
              <div class="h-4 bg-gray-300/50 dark:bg-gray-700/50 rounded w-3/4"></div>
              <div class="h-4 bg-gray-300/50 dark:bg-gray-700/50 rounded w-4/5"></div>
              <div class="h-4 bg-gray-300/50 dark:bg-gray-700/50 rounded w-1/3"></div>
            </div>

            <!-- Terminal Content (revealed dynamically) -->
            <div id="terminal-content" class="opacity-0 transition-opacity duration-500 hidden">
              <div class="text-gray-400"># Install via npm (recommended)</div>
              <div class="break-all sm:break-normal"><span class="text-egc-400">$</span> npm install -g @egchq/egc</div>
              <div><span class="text-egc-400">$</span> egc install</div>
              <div class="mt-3 text-gray-400"># Or clone from source</div>
              <div class="text-gray-500 break-all sm:break-normal"><span class="text-gray-600">$</span> git clone https://github.com/Fmarzochi/EGC.git && cd EGC && sh install.sh</div>
              <div class="mt-3 text-gray-400"># Verify</div>
              <div><span class="text-egc-400">$</span> egc doctor</div>
              <div class="mt-2 text-egc-400">egc-guardian <span class="text-green-400">running</span></div>
              <div class="text-egc-400">egc-memory <span class="text-green-400">running</span><span class="typing-cursor"></span></div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Stats -->
    <section class="border-y border-gray-100/50 dark:border-gray-800/20 bg-gradient-to-b from-transparent via-gray-100/80 to-transparent dark:from-transparent dark:via-gray-900/90 dark:to-transparent py-10 mb-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-8 text-center" data-animate>
          {[
            { value: '9', label: 'Supported Tools' },
            { value: '229+', label: 'Skills' },
            { value: '76', label: 'Commands' },
            { value: '100%', label: 'Open Source' },
          ].map(stat => (
            <div class="hover-lift">
              <div class="text-2xl sm:text-3xl font-extrabold text-egc-600 dark:text-egc-400 mb-1">{stat.value}</div>
              <div class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- The Problem -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-12 sm:mb-20" data-animate>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-3">The Problem</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4 leading-tight">Every AI session starts from zero.</h2>
          <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 leading-relaxed mb-4">Close the window and the context is gone. Your stack preferences, the architectural decisions you made last week, the approach that failed after three attempts. Next session you spend the first ten minutes re-explaining ground you already covered.</p>
          <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 leading-relaxed">It gets worse when you switch tools. Move from Cursor to Claude Code and you start over again. The AI doesn't know you. It never did.</p>
        </div>
        <div class="rounded-2xl p-4 sm:p-6 font-mono text-xs sm:text-sm glass overflow-hidden">
          <div class="text-gray-400 mb-3 text-xs">Without EGC</div>
          <div class="space-y-2 text-red-400/70 dark:text-red-400/50">
            <div class="line-through break-words">You: We're using PostgreSQL with row-level security...</div>
            <div class="line-through break-words">You: I prefer functional components, no classes...</div>
            <div class="line-through break-words">You: We tried Prisma but moved to Drizzle because...</div>
            <div class="line-through break-words">You: The auth flow uses sessions, not JWT...</div>
          </div>
          <div class="mt-4 text-gray-400 text-xs">Every. Single. Session.</div>
        </div>
      </div>
    </section>

    <!-- How EGC fixes it -->
    <section class="relative overflow-hidden bg-gradient-to-b from-transparent via-gray-100 to-transparent dark:from-transparent dark:via-gray-900/90 dark:to-transparent py-12 sm:py-20 mb-12 sm:mb-20">
      <!-- Glow Orbs for Glassmorphism Refraction -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute left-1/4 top-1/4 w-[500px] h-[500px] bg-egc-500/10 rounded-full blur-[100px] mix-blend-screen dark:bg-egc-500/10"></div>
        <div class="absolute right-1/4 bottom-1/4 w-[400px] h-[400px] bg-blue-500/10 rounded-full blur-[80px] mix-blend-screen dark:bg-blue-500/10"></div>
      </div>
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10 sm:mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-3">The Solution</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">One install. Every tool. Permanent memory.</h2>
          <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">sh install.sh detects which AI tools you have and registers the MCP servers in all of them. The AI reads your project state at the start of every session and saves decisions at the end.</p>
        </div>

        <div class="rounded-2xl overflow-hidden mb-8 glass">
          <div class="flex items-center gap-1.5 px-4 py-3 bg-gray-900 border-b border-gray-700">
            <span class="w-3 h-3 rounded-full bg-red-500"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
            <span class="w-3 h-3 rounded-full bg-green-500"></span>
            <span class="ml-2 text-xs text-gray-400 font-mono">With EGC</span>
          </div>
          <div class="bg-gray-900 p-3 sm:p-5 font-mono text-xs sm:text-sm text-gray-100 overflow-x-auto" tabindex="0" role="region" aria-label="EGC state restoration session simulation">
            <div class="text-gray-400 break-words"># You open Claude Code on a project you haven't touched in 2 weeks.</div>
            <div class="text-gray-400"># Without typing anything:</div>
            <div class="mt-3 text-egc-400">State loaded from egc-memory</div>
            <div class="text-green-400 mt-1">Context and preferences acknowledged (terse responses).</div>
            <div class="text-green-400">Ready to pick up:</div>
            <div class="text-gray-300 ml-2">• Test full install on a clean machine</div>
            <div class="text-gray-300 ml-2">• Add GEMINI.md with session memory protocol</div>
            <div class="text-gray-300 ml-2">• Publish v1.0.1 fix to npm</div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
          {[
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>',
              title: 'Open any session',
              description: 'AI reads your project state and picks up where you left off.',
            },
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/>',
              title: 'Close any session',
              description: 'AI saves decisions, preferences, and next steps automatically.',
            },
            {
              icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>',
              title: 'Switch any tool',
              description: 'Same state file, same context. No re-explaining.',
            },
          ].map(card => (
            <div class="rounded-2xl p-5 sm:p-6 hover-lift hover-glow glass relative group">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-egc-500/20 to-egc-600/5 border border-egc-500/30 flex items-center justify-center mb-5 relative overflow-hidden group-hover:border-egc-400/50 transition-colors">
                <div class="absolute inset-0 bg-egc-500/20 blur-md"></div>
                <svg class="w-6 h-6 text-egc-600 dark:text-egc-300 relative z-10 filter drop-shadow-[0_0_8px_rgba(34,197,94,0.6)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={card.icon.replace(/stroke-width="2"/g, 'stroke-width="2.5"')}></svg>
              </div>
              <h3 class="font-semibold text-gray-900 dark:text-white mb-2">{card.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Supported Tools -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-12 sm:mb-20">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-3">Ecosystem</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Works with every AI coding tool</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4" data-animate>
        {[
          { name: 'Claude Code',  badge: 'MCP + Bootstrap', icon: `${base}tools/anthropic.svg` },
          { name: 'Cursor',       badge: 'MCP + Bootstrap', icon: `${base}tools/cursor.svg` },
          { name: 'Codex CLI',    badge: 'MCP + Bootstrap', icon: `${base}tools/openai.svg` },
          { name: 'Gemini CLI',   badge: 'MCP + Bootstrap', icon: `${base}tools/googlegemini.svg` },
          { name: 'OpenCode',     badge: 'MCP + Bootstrap', icon: `${base}tools/opencode.svg` },
          { name: 'Kiro',         badge: 'MCP + Bootstrap', icon: `${base}tools/kiro.svg` },
          { name: 'Trae',         badge: 'Context + Bootstrap', icon: `${base}tools/trae.svg` },
          { name: 'CodeBuddy',    badge: 'Context + Bootstrap', icon: `${base}tools/codebuddy.svg` },
          { name: 'Antigravity',  badge: 'MCP + Bootstrap', icon: `${base}tools/bytedance.svg` },
        ].map(tool => (
          <div class="flex flex-col items-center gap-2 sm:gap-3 rounded-xl p-3 sm:p-5 text-center hover:border-egc-500 hover-glow hover-lift transition-all duration-150 active:scale-[0.97] glass">
            <div class="w-10 h-10 sm:w-14 sm:h-14 rounded-xl bg-white shadow-lg shadow-black/5 dark:shadow-black/20 flex items-center justify-center">
              <img src={tool.icon} alt={tool.name} class="w-6 h-6 sm:w-9 sm:h-9 object-contain" loading="lazy" />
            </div>
            <div class="text-xs sm:text-sm font-semibold text-gray-100 truncate w-full">{tool.name}</div>
            <div class="text-[10px] sm:text-xs text-egc-400 leading-tight">{tool.badge}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- MCP Servers -->
    <section class="bg-gradient-to-b from-transparent via-gray-100 to-transparent dark:from-transparent dark:via-gray-900/90 dark:to-transparent py-12 sm:py-20 mb-12 sm:mb-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10 sm:mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-egc-600 dark:text-egc-400 mb-3">MCP Servers</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Two local servers, zero cloud</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="rounded-2xl p-4 sm:p-6 glass hover-lift hover-glow">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-egc-50 dark:bg-egc-900/50 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-egc-600 dark:text-egc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>
                </svg>
              </div>
              <div class="min-w-0">
                <h3 class="font-bold text-gray-900 dark:text-white font-mono text-sm sm:text-base truncate">egc-memory</h3>
                <p class="text-xs text-gray-500 dark:text-gray-400">The one you'll use every session</p>
              </div>
            </div>
            <div class="space-y-2">
              {[
                { tool: 'get_state', desc: 'Reads project memory at session start' },
                { tool: 'update_state', desc: 'Saves this session\'s decisions and next steps' },
                { tool: 'store_decision', desc: 'Persists a decision to SQLite' },
                { tool: 'query_history', desc: 'Returns past decisions by timestamp' },
              ].map(row => (
                <div class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3">
                  <code class="text-xs px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200 font-mono shrink-0 self-start">{row.tool}</code>
                  <span class="text-xs text-gray-600 dark:text-gray-400">{row.desc}</span>
                </div>
              ))}
            </div>
            <a href={`${base}docs/memory`} class="mt-5 inline-flex items-center gap-1 text-xs font-semibold text-egc-600 dark:text-egc-400 hover:underline min-h-[44px]">
              Read docs
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          </div>

          <div class="rounded-2xl p-4 sm:p-6 glass hover-lift hover-glow">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center shrink-0">
