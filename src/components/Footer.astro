---
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 mt-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">

      <div class="col-span-2 md:col-span-1">
        <a href={base} class="flex items-center gap-2 mb-3">
          <img src={`${base}egc-logo.png`} alt="EGC logo" class="h-6 w-6 object-contain" />
          <span class="font-bold text-sm text-gray-900 dark:text-white">EGC</span>
        </a>
        <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">Extended Global Context.<br/>Persistent AI memory across sessions and tools.</p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">Docs</h3>
        <ul class="space-y-2">
          <li><a href={`${base}get-started`} class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">Get Started</a></li>
          <li><a href={`${base}docs/memory`} class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">Memory</a></li>
          <li><a href={`${base}docs/guardian`} class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">Guardian</a></li>
          <li><a href={`${base}docs/mcp`} class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">MCP Servers</a></li>
          <li><a href={`${base}docs/architecture`} class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">Architecture</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">Project</h3>
        <ul class="space-y-2">
          <li><a href="https://github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">GitHub</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/releases" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">Releases</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/issues" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">Issues</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">Contributing</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/blob/main/SECURITY.md" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">Security</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">Security</h3>
        <ul class="space-y-2">
          <li><a href="https://securityscorecards.dev/viewer/?uri=github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">OpenSSF Scorecard</a></li>
          <li><a href="https://www.bestpractices.dev/projects/13099" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">OpenSSF Best Practices</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/security" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors">Security Advisories</a></li>
        </ul>
      </div>
    </div>

    <!-- Sponsor -->
    <div class="border-t border-gray-200 dark:border-gray-800 pt-8 pb-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-1">Sponsors</p>
          <p class="text-xs text-gray-500 dark:text-gray-500">EGC is free and open source. Sponsors help keep it maintained.</p>
        </div>
        <a
          href="https://github.com/sponsors/Fmarzochi"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-pink-200 dark:border-pink-900/50 bg-white dark:bg-gray-950 text-pink-600 dark:text-pink-400 text-xs font-semibold hover:bg-pink-50 dark:hover:bg-pink-950/30 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 21.593c-.317.177-.834.177-1.151 0C9.774 20.57 3 16.259 3 9.5 3 6.462 5.462 4 8.5 4c1.4 0 2.672.536 3.5 1.393C12.828 4.536 14.1 4 15.5 4 18.538 4 21 6.462 21 9.5c0 6.759-6.774 11.07-9 12.093z"/>
          </svg>
          Become a sponsor
        </a>
      </div>
    </div>

    <div class="border-t border-gray-200 dark:border-gray-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-500 dark:text-gray-500">
        Released under the MIT License. &copy; 2025 Felipe Marzochi.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
