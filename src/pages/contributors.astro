---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getBase } from '../utils/base.ts';
import {
  fetchContributors,
  buildFallback,
  BADGE_DEFS,
  TIER_CONFIG,
  type MonthlyChampion,
  type Contributor,
} from '../data/contributors.ts';

const base = getBase();

let contributors: Contributor[] = [];
let monthlyChampion: MonthlyChampion | null = null;
try {
  const result = await fetchContributors(import.meta.env.GITHUB_TOKEN);
  contributors = result.contributors;
  monthlyChampion = result.champion;
} catch {
  contributors = buildFallback();
}

const topThree = contributors.slice(0, 3);
const rest = contributors.slice(3);

const totalCommits = contributors.reduce((s, c) => s + c.commits, 0);
const totalAdditions = contributors.reduce((s, c) => s + c.additions, 0);
const totalPrs = contributors.reduce((s, c) => s + c.prs, 0);

const champion = monthlyChampion
  ? (contributors.find(c => c.login === monthlyChampion!.login) ?? null)
  : null;

// Desktop podium order: 2nd left, 1st center, 3rd right
const podiumOrder = [topThree[1], topThree[0], topThree[2]].filter(Boolean) as Contributor[];
const podiumMeta = [
  { rank: 2, badge: 'bg-slate-400 text-slate-900', pedestalH: 'h-20' },
  { rank: 1, badge: 'bg-yellow-400 text-gray-900', pedestalH: 'h-36' },
  { rank: 3, badge: 'bg-amber-600 text-white',     pedestalH: 'h-12' },
];
---

<Base
  title="Hall of Fame -- EGC"
  description="The developers who shaped EGC. Every commit, every bug fix, every translation -- permanently recognized."
>
  <Navbar />

  <main id="main-content">

    <!-- Hero -->
    <section class="relative overflow-hidden py-16 sm:py-24">
      <div class="absolute inset-0 pointer-events-none -z-10" aria-hidden="true">
        <div class="absolute left-1/4 top-0 w-[600px] h-[400px] bg-yellow-400/6 rounded-full blur-[120px] mix-blend-screen"></div>
        <div class="absolute right-1/4 bottom-0 w-[400px] h-[300px] bg-egc-500/8 rounded-full blur-[100px] mix-blend-screen"></div>
      </div>

      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
        <div class="flex items-center justify-center mb-6">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl glass shadow-lg">
            <svg class="w-8 h-8 text-yellow-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17 5.8 21.3l2.4-7.4L2 9.4h7.6L12 2z"/>
            </svg>
          </div>
        </div>

        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-white mb-4">
          Hall of Fame
        </h1>
        <p class="text-base sm:text-lg text-gray-400 max-w-xl mx-auto mb-10">
          Every developer who shipped something real for EGC is here permanently. No bots, no placeholders. Just the people who looked at an open issue and fixed it.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-14">
          {[
            { value: String(contributors.length), label: 'Contributors' },
            { value: String(totalCommits || '--'), label: 'Commits' },
            { value: totalAdditions > 0 ? `+${totalAdditions.toLocaleString('en')}` : '--', label: 'Lines added' },
            { value: String(totalPrs), label: 'PRs merged' },
          ].map(s => (
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-extrabold text-egc-400">{s.value}</div>
              <div class="text-xs text-gray-500 uppercase tracking-widest mt-1">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contributor of the Month -->
    {champion && (
      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-12">
        <div class="relative rounded-2xl overflow-hidden glass">
          <div class="absolute inset-0 pointer-events-none -z-10" aria-hidden="true">
            <div class="absolute inset-0 bg-gradient-to-r from-yellow-400/5 via-transparent to-egc-500/5"></div>
          </div>
          <button type="button" data-hype={champion.login} title="Hype this contributor (1 vote a day)" aria-label={`Hype ${champion.name}`} class="hype-btn absolute top-3 right-3 z-10 inline-flex items-center gap-1 h-7 px-2 rounded-full text-xs font-semibold backdrop-blur-md bg-white/10 border border-white/15 text-gray-300 hover:text-orange-400 hover:border-orange-400/40 motion-safe:hover:scale-105 motion-safe:active:scale-95 transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-400">🔥<span class="hype-count tabular-nums"></span></button>
          <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6 p-5 sm:p-8">
            <div class="shrink-0">
              <div class="relative">
                <img
                  src={champion.avatar}
                  alt={champion.name}
                  width="72"
                  height="72"
                  class="rounded-full ring-2 ring-yellow-400/60"
                  loading="lazy"
                />
                <span class="absolute -bottom-1 -right-1 text-lg leading-none">🏅</span>
              </div>
            </div>
            <div class="flex-1 text-center sm:text-left">
              <div class="flex items-center justify-center sm:justify-start gap-2 mb-1">
                <span class="text-xs font-bold uppercase tracking-widest text-yellow-400">Contributor of the Month</span>
                <span class="text-xs text-gray-600">{monthlyChampion!.month}</span>
              </div>
              <p class="font-bold text-white text-base sm:text-lg">{champion.name}</p>
              <p class="text-xs text-gray-500 mb-2">@{champion.login}</p>
              <p class="text-sm text-gray-400 leading-relaxed">{monthlyChampion!.reason}</p>
            </div>
            <a
              href={`${base}contributors/${champion.login}`}
              class="shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-yellow-400/10 hover:bg-yellow-400/20 text-yellow-300 text-sm font-semibold border border-yellow-400/30 transition-colors duration-200 active:scale-95"
            >
              View profile
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- Podium -->
    {topThree.length >= 3 && (
      <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-4">
        <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-1 text-center">Leaderboard</p>
        <p class="text-xs text-gray-600 mb-6 sm:mb-8 text-center">🔥 Hype your favorite contributor, one vote a day</p>

        <!-- Mobile: ranked list -->
        <div class="sm:hidden flex flex-col gap-3">
          {topThree.map((c, i) => {
            const rankBadge = ['bg-yellow-400 text-gray-900', 'bg-slate-400 text-slate-900', 'bg-amber-600 text-white'][i];
            const tier = TIER_CONFIG[c.tier];
            return (
              <div class="relative">
              <button type="button" data-hype={c.login} title="Hype this contributor (1 vote a day)" aria-label={`Hype ${c.name}`} class="hype-btn absolute -top-2 -right-1 z-10 inline-flex items-center gap-1 h-7 px-2 rounded-full text-xs font-semibold backdrop-blur-md bg-white/10 border border-white/15 text-gray-300 hover:text-orange-400 hover:border-orange-400/40 motion-safe:hover:scale-105 motion-safe:active:scale-95 transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-400">🔥<span class="hype-count tabular-nums"></span></button>
              <a
                href={`${base}contributors/${c.login}`}
                class={`group flex items-center gap-3 rounded-2xl p-4 glass hover-lift transition-all duration-200 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500 ${i === 0 ? 'ring-2 ring-yellow-400/30' : ''}`}
              >
                <div class={`shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold shadow ${rankBadge}`}>{i + 1}</div>
                <img
                  src={c.avatar}
                  alt={c.name}
                  width={i === 0 ? '52' : '44'}
                  height={i === 0 ? '52' : '44'}
                  class={`rounded-full ring-2 shrink-0 ${i === 0 ? 'ring-yellow-400/60' : 'ring-gray-700'}`}
                  loading="lazy"
                />
                <div class="min-w-0 flex-1">
                  <p class="font-bold text-white text-sm truncate">{c.name}</p>
                  <p class="text-xs text-gray-500 mb-1">@{c.login}</p>
                  <div class="flex items-center gap-1 flex-wrap">
                    <span class={`inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded-full text-xs font-semibold border ${tier.color}`}>{tier.icon}</span>
                    {c.badges.slice(0, 3).map(key => {
                      const b = BADGE_DEFS[key];
                      return b ? <span title={b.label}>{b.icon}</span> : null;
                    })}
                  </div>
                </div>
                <div class="shrink-0 text-right">
                  <span class="block text-sm font-bold text-egc-400">{c.commits > 0 ? c.commits : c.prs}</span>
                  <span class="block text-xs text-gray-600">{c.commits > 0 ? 'commits' : 'PRs'}</span>
                </div>
              </a>
              </div>
            );
          })}
        </div>

        <!-- Desktop: visual podium (2nd, 1st, 3rd) -->
        <div class="hidden sm:flex items-end justify-center gap-2">
          {podiumOrder.map((c, idx) => {
            const meta = podiumMeta[idx];
            const tier = TIER_CONFIG[c.tier];
            return (
              <div class="relative flex flex-col items-center flex-1 max-w-[210px]">
                <button type="button" data-hype={c.login} title="Hype this contributor (1 vote a day)" aria-label={`Hype ${c.name}`} class="hype-btn absolute top-2 right-2 z-10 inline-flex items-center gap-1 h-7 px-2 rounded-full text-xs font-semibold backdrop-blur-md bg-white/10 border border-white/15 text-gray-300 hover:text-orange-400 hover:border-orange-400/40 motion-safe:hover:scale-105 motion-safe:active:scale-95 transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-400">🔥<span class="hype-count tabular-nums"></span></button>
                <a
                  href={`${base}contributors/${c.login}`}
                  class={`group w-full flex flex-col items-center glass hover-lift rounded-t-2xl px-5 pt-6 pb-4 transition-all duration-300 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500 ${meta.rank === 1 ? 'ring-2 ring-yellow-400/40' : ''}`}
                >
                  <div class="relative mb-3">
                    <img
                      src={c.avatar}
                      alt={c.name}
                      width={meta.rank === 1 ? '72' : '56'}
                      height={meta.rank === 1 ? '72' : '56'}
                      class={`rounded-full ring-2 transition-all duration-200 block ${meta.rank === 1 ? 'ring-yellow-400/60 group-hover:ring-yellow-400' : 'ring-gray-700 group-hover:ring-egc-500'}`}
                      loading="lazy"
                    />
                    <div class={`absolute -bottom-1 -right-1 w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shadow-lg ${meta.badge}`}>
                      {meta.rank}
                    </div>
                  </div>
                  <p class="font-bold text-white text-sm text-center leading-tight mb-0.5">{c.name}</p>
                  <p class="text-xs text-gray-500 mb-2">@{c.login}</p>
                  <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold border ${tier.color} mb-2`}>
                    {tier.icon} {tier.label}
                  </span>
                  <div class="flex flex-wrap justify-center gap-1 mb-2">
                    {c.badges.slice(0, 2).map(key => {
                      const b = BADGE_DEFS[key];
                      return b ? <span class="text-sm" title={b.label}>{b.icon}</span> : null;
                    })}
                  </div>
                  <span class="text-xs font-bold text-egc-400">
                    {c.commits > 0 ? `${c.commits} commit${c.commits !== 1 ? 's' : ''}` : `${c.prs} PR${c.prs !== 1 ? 's' : ''}`}
                  </span>
                </a>
                <!-- Pedestal step -->
                <div class={`w-full ${meta.pedestalH} rounded-b-xl relative overflow-hidden flex items-center justify-center
                  ${meta.rank === 1 ? 'bg-gradient-to-b from-yellow-400/25 to-yellow-400/8'
                  : meta.rank === 2 ? 'bg-gradient-to-b from-slate-400/20 to-slate-400/6'
                  : 'bg-gradient-to-b from-amber-600/20 to-amber-600/6'}`}>
                  <div class={`absolute top-0 left-0 right-0 h-0.5
                    ${meta.rank === 1 ? 'bg-yellow-400/70'
                    : meta.rank === 2 ? 'bg-slate-400/55'
                    : 'bg-amber-600/50'}`}></div>
                  <span class={`font-black select-none leading-none opacity-40
                    ${meta.rank === 1 ? 'text-6xl text-yellow-400'
                    : meta.rank === 2 ? 'text-5xl text-slate-400'
                    : 'text-4xl text-amber-600'}`}>{meta.rank}</span>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- All contributors grid -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mt-12 mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-1">All contributors</p>
      <p class="text-xs text-gray-600 mb-6">🔥 Hype your favorite contributor, one vote a day</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {rest.map(c => {
          const tier = TIER_CONFIG[c.tier];
          return (
            <div class="relative">
            <button type="button" data-hype={c.login} title="Hype this contributor (1 vote a day)" aria-label={`Hype ${c.name}`} class="hype-btn absolute -top-2 -right-1 z-10 inline-flex items-center gap-1 h-7 px-2 rounded-full text-xs font-semibold backdrop-blur-md bg-white/10 border border-white/15 text-gray-300 hover:text-orange-400 hover:border-orange-400/40 motion-safe:hover:scale-105 motion-safe:active:scale-95 transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-400">🔥<span class="hype-count tabular-nums"></span></button>
            <a
              href={`${base}contributors/${c.login}`}
              class="group flex items-center gap-4 rounded-xl p-4 glass hover-lift transition-all duration-200 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500"
            >
              <img
                src={c.avatar}
                alt={c.name}
                width="48"
                height="48"
                class="rounded-full ring-2 ring-transparent group-hover:ring-egc-500 transition-all duration-200 shrink-0"
                loading="lazy"
              />
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-0.5">
                  <p class="font-semibold text-white text-sm truncate">{c.name}</p>
                  <span class={`shrink-0 inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full text-xs font-semibold border ${tier.color}`}>
                    {tier.icon}
                  </span>
                </div>
                <p class="text-xs text-gray-500 mb-1">@{c.login}</p>
                <div class="flex items-center gap-1.5 flex-wrap">
                  {c.badges.map(key => {
                    const b = BADGE_DEFS[key];
                    return b ? (
                      <span class={`inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded-full text-xs font-medium ${b.color}`}>
                        {b.icon} {b.label}
                      </span>
                    ) : null;
                  })}
                </div>
              </div>
              <div class="ml-auto shrink-0 text-right">
                <span class="block text-xs font-bold text-egc-400">
                  {c.commits > 0 ? `${c.commits} commit${c.commits !== 1 ? 's' : ''}` : 'co-author'}
                </span>
                <span class="block text-xs text-gray-600">{c.prs} PR{c.prs !== 1 ? 's' : ''}</span>
                {c.additions > 0 && <span class="block text-xs text-gray-700">+{c.additions.toLocaleString('en')}</span>}
              </div>
            </a>
            </div>
          );
        })}
      </div>

      <!-- Tier legend -->
      <div class="mt-8 rounded-xl p-4 glass">
        <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-3">Tiers</p>
        <div class="flex flex-wrap gap-2 sm:gap-3">
          {(Object.entries(TIER_CONFIG) as [string, typeof TIER_CONFIG[keyof typeof TIER_CONFIG]][]).map(([, t]) => (
            <span class={`inline-flex items-center gap-1 sm:gap-1.5 px-2 sm:px-3 py-1 rounded-full text-xs font-semibold border ${t.color}`}>
              {t.icon} <span class="hidden sm:inline">{t.label}</span><span class="sm:hidden">{t.label.split(' ')[0]}</span>
              <span class="opacity-50 hidden sm:inline">({t.minCommits}+ commits)</span>
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 mb-16">
      <div class="rounded-2xl p-6 sm:p-8 text-center glass hover-glow">
        <p class="text-sm text-gray-400 mb-4">
          Want your name on this page? Find an open issue and ship a fix.
        </p>
        <a
          href="https://github.com/Fmarzochi/EGC/issues"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-egc-600 hover:bg-egc-500 text-white text-sm font-semibold transition-colors duration-200 active:scale-95"
        >
          Browse open issues
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </section>

    <!-- Sponsors -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20">
      <div class="relative rounded-2xl p-6 sm:p-10 glass hover-glow overflow-hidden">
        <div class="absolute inset-0 pointer-events-none -z-10" aria-hidden="true">
          <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[300px] bg-pink-500/10 rounded-full blur-[80px] mix-blend-screen"></div>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-10">
          <div class="text-center sm:text-left">
            <div class="flex items-center justify-center sm:justify-start gap-2 mb-1">
              <svg class="w-5 h-5 text-pink-500 animate-heartbeat" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 21.593c-.317.177-.834.177-1.151 0C9.774 20.57 3 16.259 3 9.5 3 6.462 5.462 4 8.5 4c1.4 0 2.672.536 3.5 1.393C12.828 4.536 14.1 4 15.5 4 18.538 4 21 6.462 21 9.5c0 6.759-6.774 11.07-9 12.093z"/>
              </svg>
              <h2 class="text-lg font-bold text-white">Sponsors</h2>
            </div>
            <p class="text-xs text-gray-500 max-w-xs">EGC is free and open source. Sponsors keep it alive and moving forward.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
            <a
              href="https://github.com/sponsors/Fmarzochi"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center gap-2 min-h-[40px] px-4 py-2 rounded-xl border border-gray-700 bg-gray-900 text-gray-300 text-sm font-semibold hover:border-pink-700 hover:text-pink-400 active:scale-95 transition-all duration-200"
            >
              <svg class="w-4 h-4 text-pink-500/70 group-hover:text-pink-400 transition-colors animate-heartbeat" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21.593c-.317.177-.834.177-1.151 0C9.774 20.57 3 16.259 3 9.5 3 6.462 5.462 4 8.5 4c1.4 0 2.672.536 3.5 1.393C12.828 4.536 14.1 4 15.5 4 18.538 4 21 6.462 21 9.5c0 6.759-6.774 11.07-9 12.093z"/></svg>
              GitHub Sponsors
            </a>
            <a
              href="https://www.paypal.com/donate/?business=fmarzochi%40gmail.com&currency_code=USD"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center gap-2 min-h-[40px] px-4 py-2 rounded-xl border border-gray-700 bg-gray-900 text-gray-300 text-sm font-semibold hover:border-blue-700 hover:text-blue-400 active:scale-95 transition-all duration-200"
            >
              <svg class="w-4 h-4 text-blue-500/70 group-hover:text-blue-400 transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516a.56.56 0 0 0 .554.647h3.882c.46 0 .85-.334.922-.788.06-.26.76-4.852.816-5.09a.932.932 0 0 1 .923-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"/></svg>
              PayPal
            </a>
          </div>
        </div>

        <div class="mb-8">
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-2">Tool Partners</p>
          <p class="text-xs text-gray-600 italic mb-4">Be the first tool partner.</p>
          <div class="flex flex-wrap gap-3">
            <a
              href="https://www.pincushion.io/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Pincushion -- AI feedback tool (opens in new tab)"
              class="group relative focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500 rounded-full"
            >
              <div class="w-[80px] h-[80px] rounded-full overflow-hidden ring-2 ring-transparent group-hover:ring-egc-400 transition-all duration-200">
                <img
                  src="https://www.pincushion.io/logo-icon.png"
                  alt="Pincushion"
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            </a>
          </div>
        </div>

        <div class="mb-8">
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4">Monthly sponsors</p>
          <p class="text-xs text-gray-600 italic">Be the first monthly sponsor.</p>
        </div>

        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-4">Backers</p>
          <div class="flex flex-wrap gap-3">
            <a
              href="https://github.com/chizormaangel-commits"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="@chizormaangel-commits on GitHub (opens in new tab)"
              class="group relative focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500 rounded-full"
            >
              <img
                src="https://avatars.githubusercontent.com/u/291871326?v=4"
                alt="@chizormaangel-commits"
                width="52"
                height="52"
                class="rounded-full ring-2 ring-transparent group-hover:ring-pink-400 transition-all duration-200"
                loading="lazy"
              />
            </a>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />

  <style is:global>
    .hype-btn.hype-voted {
      color: #fb923c;
      border-color: rgba(251, 146, 60, 0.4);
      background: rgba(249, 115, 22, 0.12);
      cursor: default;
    }
    .hype-btn.hype-voted:hover { transform: none; }
  </style>

  <script>
    const NS = 'egc-halloffame';
    const API = 'https://abacus.jasoncameron.dev';
    const btns = Array.from(document.querySelectorAll('.hype-btn')) as HTMLButtonElement[];
    const today = new Date().toISOString().slice(0, 10);

    function byLogin(login: string) {
      return btns.filter(b => b.dataset.hype === login);
    }
    function paintVoted(b: HTMLButtonElement) {
      b.classList.add('hype-voted');
      b.setAttribute('aria-pressed', 'true');
      b.title = 'Already hyped today! Resets tomorrow';
    }
    function setCount(login: string, value: number) {
      for (const b of byLogin(login)) {
        const el = b.querySelector('.hype-count');
        if (el) el.textContent = String(value);
      }
    }

    for (const b of btns) {
      const login = b.dataset.hype || '';
      if (localStorage.getItem(`hype:${login}:${today}`)) paintVoted(b);
      b.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const key = `hype:${login}:${today}`;
        if (localStorage.getItem(key)) return;
        localStorage.setItem(key, '1');
        for (const twin of byLogin(login)) paintVoted(twin);
        const el = b.querySelector('.hype-count');
        const cur = parseInt(el?.textContent || '0', 10) || 0;
        setCount(login, cur + 1);
        // Fire-and-forget: o Abacus grava o voto global; keepalive garante o envio
        // mesmo se a aba fechar. Sem rollback: a trava do localStorage ja impede repeticao.
        try { fetch(`${API}/hit/${NS}/${encodeURIComponent(login)}`, { keepalive: true }); } catch { /* offline: voto local mantido */ }
      });
    }

    const logins = Array.from(new Set(btns.map(b => b.dataset.hype || '').filter(Boolean)));
    Promise.all(
      logins.map(login =>
        fetch(`${API}/get/${NS}/${encodeURIComponent(login)}`)
          .then(r => (r.ok ? r.json() : { value: 0 }))
          .then(d => [login, typeof d.value === 'number' ? d.value : 0] as const)
          .catch(() => [login, null] as const)
      )
    ).then(pairs => {
      for (const [login, value] of pairs) {
        // null = servico inacessivel (adblock/offline): botao segue funcional, numero oculto
        if (value !== null) setCount(login, value);
      }
    });
  </script>
</Base>
