---
import Base from './Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  current?: string;
}

const { title, description, current } = Astro.props;
const base = import.meta.env.BASE_URL;

const sections = [
  {
    label: 'Getting Started',
    links: [
      { href: `${base}get-started`, label: 'Installation', id: 'get-started' },
      { href: `${base}features`, label: 'Features', id: 'features' },
    ],
  },
  {
    label: 'MCP Servers',
    links: [
      { href: `${base}docs/memory`, label: 'egc-memory', id: 'memory' },
      { href: `${base}docs/guardian`, label: 'egc-guardian', id: 'guardian' },
      { href: `${base}docs/mcp`, label: 'Overview', id: 'mcp' },
    ],
  },
  {
    label: 'Reference',
    links: [
      { href: `${base}docs/architecture`, label: 'Architecture', id: 'architecture' },
      { href: `${base}docs/security`, label: 'Security', id: 'security' },
      { href: `${base}docs/cli`, label: 'CLI Reference', id: 'cli' },
      { href: `${base}docs/faq`, label: 'FAQ', id: 'faq' },
    ],
  },
  {
    label: 'Community',
    links: [
      { href: 'https://github.com/Fmarzochi/EGC/blob/main/CONTRIBUTING.md', label: 'Contributing', id: 'contributing', external: true },
      { href: 'https://github.com/Fmarzochi/EGC/releases', label: 'Releases', id: 'releases', external: true },
    ],
  },
];
---

<Base title={`${title} - EGC Docs`} description={description}>
  <Navbar />
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex gap-8 py-8 min-h-screen">

      <aside class="hidden lg:block w-56 shrink-0">
        <div class="sticky top-20">
          {sections.map(section => (
            <div class="mb-6">
              <p class="mb-1.5 px-3 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{section.label}</p>
              <ul class="space-y-0.5">
                {section.links.map(link => (
                  <li>
                    <a
                      href={link.href}
                      target={link.external ? '_blank' : undefined}
                      rel={link.external ? 'noopener noreferrer' : undefined}
                      class={`flex items-center justify-between px-3 py-1.5 rounded-lg text-sm transition-colors duration-150 ${
                        current === link.id
                          ? 'text-egc-700 dark:text-egc-400 bg-egc-50 dark:bg-egc-950/50 font-medium'
                          : 'text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 hover:bg-gray-100 dark:hover:bg-gray-800'
                      }`}
                    >
                      {link.label}
                      {link.external && (
                        <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </aside>

      <main class="flex-1 min-w-0 max-w-3xl">
        <slot />
      </main>

    </div>
  </div>
  <Footer />
</Base>
