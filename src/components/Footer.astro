---
const b = import.meta.env.BASE_URL;
const base = b.endsWith('/') ? b : b + '/';
---

<footer class="border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 mt-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 sm:py-12">

    <!-- Footer grid: 1 col mobile → 2 col small → 4 col desktop -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-10 mb-10">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={base} class="inline-flex items-center gap-2 mb-3 min-h-[44px]">
          <img src={`${base}egc-logo.png`} alt="EGC logo" class="h-6 w-6 object-contain shrink-0" />
          <span class="font-bold text-sm text-gray-900 dark:text-white">EGC</span>
        </a>
        <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed max-w-xs">Extended Global Context.<br/>Persistent AI memory across sessions and tools.</p>
      </div>

      <!-- Docs column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">Docs</h3>
        <ul class="space-y-0.5">
          <li><a href={`${base}get-started`} class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">Get Started</a></li>
          <li><a href={`${base}docs/memory`} class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">Memory</a></li>
          <li><a href={`${base}docs/guardian`} class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">Guardian</a></li>
          <li><a href={`${base}docs/mcp`} class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">MCP Servers</a></li>
          <li><a href={`${base}docs/architecture`} class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">Architecture</a></li>
        </ul>
      </div>

      <!-- Project column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">Project</h3>
        <ul class="space-y-0.5">
          <li><a href="https://github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">GitHub</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/releases" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">Releases</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/issues" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">Issues</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">Contributing</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/blob/main/SECURITY.md" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">Security</a></li>
        </ul>
      </div>

      <!-- Security column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3">Security</h3>
        <ul class="space-y-0.5">
          <li><a href="https://securityscorecards.dev/viewer/?uri=github.com/Fmarzochi/EGC" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">OpenSSF Scorecard</a></li>
          <li><a href="https://www.bestpractices.dev/projects/13099" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">OpenSSF Best Practices</a></li>
          <li><a href="https://github.com/Fmarzochi/EGC/security" target="_blank" rel="noopener noreferrer" class="inline-flex items-center min-h-[44px] px-1 -ml-1 text-sm text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 transition-colors duration-150">Security Advisories</a></li>
        </ul>
      </div>
    </div>

    <!-- Sponsor section -->
    <div class="border-t border-gray-200 dark:border-gray-800 pt-8 pb-6">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-1">Sponsors</p>
          <p class="text-xs text-gray-500 dark:text-gray-500 max-w-sm">EGC is free and open source. Sponsors help keep it maintained.</p>
        </div>
        <div class="flex flex-col xs:flex-row sm:flex-row gap-2 w-full sm:w-auto">
          <a
            href="https://github.com/sponsors/Fmarzochi"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-2 min-h-[44px] px-4 py-2.5 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 text-gray-600 dark:text-gray-400 text-xs font-semibold hover:border-pink-300 dark:hover:border-pink-800/80 hover:text-pink-600 dark:hover:text-pink-400 hover:bg-pink-50/30 dark:hover:bg-pink-950/20 active:scale-95 transition-all duration-200"
          >
            <svg class="w-4 h-4 text-pink-500/70 dark:text-pink-500/50 group-hover:text-pink-500 dark:group-hover:text-pink-400 transition-colors shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 21.593c-.317.177-.834.177-1.151 0C9.774 20.57 3 16.259 3 9.5 3 6.462 5.462 4 8.5 4c1.4 0 2.672.536 3.5 1.393C12.828 4.536 14.1 4 15.5 4 18.538 4 21 6.462 21 9.5c0 6.759-6.774 11.07-9 12.093z"/>
            </svg>
            GitHub Sponsors
          </a>
          <a
            href="https://www.paypal.com/donate/?business=fmarzochi%40gmail.com&currency_code=USD"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-2 min-h-[44px] px-4 py-2.5 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 text-gray-600 dark:text-gray-400 text-xs font-semibold hover:border-blue-300 dark:hover:border-blue-800/80 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50/30 dark:hover:bg-blue-950/20 active:scale-95 transition-all duration-200"
          >
            <svg class="w-4 h-4 text-blue-500/70 dark:text-blue-500/50 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516a.56.56 0 0 0 .554.647h3.882c.46 0 .85-.334.922-.788.06-.26.76-4.852.816-5.09a.932.932 0 0 1 .923-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"/>
            </svg>
            PayPal
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-200 dark:border-gray-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-500 dark:text-gray-500 text-center sm:text-left">
        Released under the <a href="https://github.com/Fmarzochi/EGC/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="hover:text-gray-700 dark:hover:text-gray-300 transition-colors cursor-pointer">MIT License</a>. &copy; 2025 <a href="https://github.com/Fmarzochi" target="_blank" rel="noopener noreferrer" class="hover:text-gray-700 dark:hover:text-gray-300 transition-colors cursor-pointer">Felipe Marzochi</a>.
      </p>
      <div class="flex items-center gap-1">
        <a
          href="https://github.com/Fmarzochi/EGC"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="inline-flex items-center justify-center min-w-[44px] min-h-[44px] rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-all duration-150"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
