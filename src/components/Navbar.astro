---
import { getBase } from '../utils/base.ts';
import Icon from './Icon.astro';
const base = getBase();
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}get-started`, label: 'Get Started' },
  { href: `${base}features`, label: 'Features' },
  { href: `${base}docs/memory`, label: 'Docs' },
  { href: `${base}contributors`, label: 'Hall of Fame' },
  { href: 'https://github.com/Fmarzochi/EGC', label: 'GitHub', external: true },
];
---

<header id="site-header" class="sticky top-0 z-50 w-full border-b border-gray-200 dark:border-gray-800 bg-white/90 dark:bg-gray-950/90 backdrop-blur-md transition-transform duration-300 transform translate-y-0">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">

      <!-- Logo + brand -->
      <div class="flex items-center gap-2 shrink-0">
        <a href={base} class="flex items-center gap-2.5 min-h-[44px] group">
          <img src={`${base}egc-logo.png`} alt="EGC Logo" class="h-8 w-8 sm:h-10 sm:w-10 object-contain shrink-0 drop-shadow-md group-hover:scale-110 transition-transform duration-200" />
          <span class="font-extrabold text-lg sm:text-2xl tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-300 whitespace-nowrap">EGC</span>
        </a>
      </div>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            aria-label={link.external ? `${link.label} (opens in new tab)` : undefined}
            class="px-3 py-1.5 rounded-md text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-egc-600 dark:hover:text-egc-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-150 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500"
          >
            {link.label}
            {link.external && (
              <Icon name="external" size={12} class="inline-block ml-0.5 opacity-60" />
            )}
          </a>
        ))}
      </nav>

      <!-- Right side: desktop CTA + mobile hamburger -->
      <div class="flex items-center gap-2">
        <a
          href="https://huggingface.co/spaces/fmarzochi/EGC"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Hugging Face Space (opens in new tab)"
          class="hidden md:inline-flex items-center justify-center w-9 h-9 rounded-lg text-base hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-150 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500"
        >
          <span aria-hidden="true">🤗</span>
        </a>
        <a
          href="https://discord.gg/TxppsGb52"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Discord (opens in new tab)"
          class="hidden md:inline-flex items-center justify-center w-9 h-9 rounded-lg text-gray-500 dark:text-gray-400 hover:text-indigo-500 dark:hover:text-indigo-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-150 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500"
        >
          <Icon name="discord" size={18} />
        </a>
        <a
          href="https://github.com/Fmarzochi/EGC"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub (opens in new tab)"
          class="hidden md:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gray-900 dark:bg-white text-white dark:text-gray-900 text-xs font-semibold hover:bg-gray-700 dark:hover:bg-gray-100 transition-colors duration-150 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500"
        >
          <Icon name="github" size={14} />
          GitHub
        </a>

        <!-- Hamburger button (mobile only) -->
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="md:hidden p-2.5 min-w-[44px] min-h-[44px] flex flex-col items-center justify-center gap-[5px] rounded-lg focus:outline-none focus:ring-2 focus:ring-egc-500 focus:ring-offset-1 dark:focus:ring-offset-gray-950 active:scale-95 transition-all duration-150"
        >
          <span class="block w-6 h-[2px] bg-gray-600 dark:bg-gray-400 rounded-full transition-all duration-300 origin-center line-1"></span>
          <span class="block w-6 h-[2px] bg-gray-600 dark:bg-gray-400 rounded-full transition-all duration-300 line-2"></span>
          <span class="block w-6 h-[2px] bg-gray-600 dark:bg-gray-400 rounded-full transition-all duration-300 origin-center line-3"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Backdrop overlay -->
<div
  id="mobile-backdrop"
    class="fixed inset-0 bg-black/20 dark:bg-black/40 backdrop-blur-sm z-[-1] opacity-0 pointer-events-none invisible transition-opacity duration-300 md:hidden"
    aria-hidden="true"
  ></div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 top-[64px] border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 overflow-y-auto transition-all duration-300 ease-in-out opacity-0 pointer-events-none invisible z-40"
  >
    <nav class="flex flex-col gap-3 px-6 py-8">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          aria-label={link.external ? `${link.label} (opens in new tab)` : undefined}
          class:list={[
            'mobile-nav-link flex items-center min-h-[56px] px-4 py-3 rounded-xl text-xl font-semibold text-gray-700 dark:text-gray-300 hover:text-egc-600 dark:hover:text-egc-400 hover:bg-gray-50 dark:hover:bg-gray-900 active:scale-[0.98] active:bg-gray-100 dark:active:bg-gray-800 transition-all duration-150 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500',
            `mobile-nav-link-${i}`,
          ]}
        >
          {link.label}
          {link.external && (
            <Icon name="external" size={16} class="ml-1.5 opacity-50" />
          )}
        </a>
      ))}

      <!-- GitHub CTA in mobile menu -->
      <div class="mt-2 pt-2 border-t border-gray-100 dark:border-gray-800">
        <a
          href="https://github.com/Fmarzochi/EGC"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Star on GitHub (opens in new tab)"
          class="mobile-nav-link flex items-center justify-center gap-2 min-h-[44px] px-4 py-2.5 rounded-lg bg-gray-900 dark:bg-white text-white dark:text-gray-900 text-sm font-semibold hover:bg-gray-700 dark:hover:bg-gray-100 active:scale-[0.98] transition-all duration-150 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-egc-500"
        >
          <Icon name="github" size={16} />
          Star on GitHub
        </a>
      </div>
    </nav>
  </div>
</div>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-backdrop');

  function openMenu() {
    mobileMenuBtn?.setAttribute('aria-expanded', 'true');
    mobileMenuBtn?.setAttribute('aria-label', 'Close menu');
    mobileMenu?.classList.remove('opacity-0', 'pointer-events-none', 'invisible');
    mobileMenu?.classList.add('opacity-100', 'pointer-events-auto', 'visible');
    backdrop?.classList.remove('opacity-0', 'pointer-events-none', 'invisible');
    backdrop?.classList.add('opacity-100', 'pointer-events-auto', 'visible');
    document.body.style.overflow = 'hidden';

    // Staggered link entrance
    const links = mobileMenu?.querySelectorAll('.mobile-nav-link');
    links?.forEach((link, i) => {
      const el = link as HTMLElement;
      el.style.opacity = '0';
      el.style.transform = 'translateY(-8px)';
      setTimeout(() => {
        el.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, 50 + i * 40);
    });
  }

  function closeMenu() {
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    mobileMenuBtn?.setAttribute('aria-label', 'Open menu');
    mobileMenu?.classList.add('opacity-0', 'pointer-events-none', 'invisible');
    mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto', 'visible');
    backdrop?.classList.add('opacity-0', 'pointer-events-none', 'invisible');
    backdrop?.classList.remove('opacity-100', 'pointer-events-auto', 'visible');
    document.body.style.overflow = '';
  }

  function isMenuOpen(): boolean {
    return mobileMenuBtn?.getAttribute('aria-expanded') === 'true';
  }

  // Toggle on hamburger click
  mobileMenuBtn?.addEventListener('click', () => {
    if (isMenuOpen()) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // Close on backdrop click
  backdrop?.addEventListener('click', closeMenu);

  // Close on link click (for same-page navigation)
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isMenuOpen()) {
      closeMenu();
      mobileMenuBtn?.focus();
    }
  });

  // Close menu on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && isMenuOpen()) {
      closeMenu();
    }
  });

  // Scroll dynamics (hide/show header on scroll)
  let lastScrollY = window.scrollY;
  let scrollTimeout: ReturnType<typeof setTimeout> | undefined;
  const header = document.getElementById('site-header');

  if (header) {
    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;

      if (scrollTimeout) clearTimeout(scrollTimeout);

      // Don't hide header while mobile menu is open
      if (isMenuOpen()) {
        lastScrollY = currentScrollY;
        return;
      }

      if (currentScrollY > 64) {
        if (currentScrollY > lastScrollY) {
          header.classList.add('-translate-y-full');
          header.classList.remove('translate-y-0');
        } else {
          header.classList.add('translate-y-0');
          header.classList.remove('-translate-y-full');
        }
      } else {
        header.classList.add('translate-y-0');
        header.classList.remove('-translate-y-full');
      }

      lastScrollY = currentScrollY;

      scrollTimeout = setTimeout(() => {
        header.classList.add('translate-y-0');
        header.classList.remove('-translate-y-full');
      }, 250);
    }, { passive: true });
  }
</script>

<style>
  /* Hamburger → X animation */
  #mobile-menu-btn[aria-expanded="true"] .line-1 {
    transform: translateY(7px) rotate(45deg);
  }
  #mobile-menu-btn[aria-expanded="true"] .line-2 {
    opacity: 0;
  }
  #mobile-menu-btn[aria-expanded="true"] .line-3 {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Ensure mobile menu is on top of page content */
  #mobile-menu {
    z-index: 40;
  }
  #mobile-backdrop {
    z-index: 30;
  }
</style>
